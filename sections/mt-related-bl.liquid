      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "title_desktop_margin",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Titel ruimte onder (desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_mobile_size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte mobiel",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_mobile_margin",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Titel ruimte onder (mobiel)",
      "default": 16
    },
    {
      "type": "header",
      "content": "Desktop lay-out"
    },
