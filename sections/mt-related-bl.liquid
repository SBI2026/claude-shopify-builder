{%- assign mfont = section.settings.font_family | default: 'Poppins' -%}
{%- assign mfont_url = mfont | replace: ' ', '+' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family={{ mfont_url }}:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- style -%}
  /* ── Mobile-first variables ── */
  #shopify-section-{{ section.id }} {
    --pt:              {{ section.settings.padding_top_mobile }}px;
    --pb:              {{ section.settings.padding_bottom_mobile }}px;
    --ph:              {{ section.settings.padding_h_mobile }}px;
    --title-size:      {{ section.settings.title_size_mobile }}px;
    --title-color:     {{ section.settings.title_color }};
    --title-weight:    {{ section.settings.title_weight }};
    --title-spacing:   {{ section.settings.title_letter_spacing | times: 0.01 }}em;
    --title-transform: {{ section.settings.title_transform }};
    --title-mb:        {{ section.settings.title_margin_bottom }}px;
    --desc-color:      {{ section.settings.desc_color }};
    --desc-size:       {{ section.settings.desc_size }}px;
    --desc-weight:     {{ section.settings.desc_weight }};
    --desc-lh:         {{ section.settings.desc_line_height }};
    --desc-max-w:      {{ section.settings.desc_max_width }}px;
    --desc-mb:         {{ section.settings.desc_margin_bottom }}px;
    --divider-color:   {{ section.settings.divider_color }};
    --divider-mb:      {{ section.settings.divider_margin_bottom }}px;
    --sub-color:       {{ section.settings.sub_label_color }};
    --sub-size:        {{ section.settings.sub_label_size }}px;
    --sub-weight:      {{ section.settings.sub_label_weight }};
    --sub-spacing:     {{ section.settings.sub_label_letter_spacing | times: 0.01 }}em;
    --sub-transform:   {{ section.settings.sub_label_transform }};
    --sub-mb:          {{ section.settings.sub_label_margin_bottom }}px;
    --cols:            1;
    --gap:             {{ section.settings.grid_gap_mobile }}px;
    --photo-aspect:    {{ section.settings.photo_aspect_mobile }};
    --photo-radius:    {{ section.settings.photo_radius_mobile }}px;
    --photo-bg:        {{ section.settings.photo_bg }};
    --photo-fit:       {{ section.settings.photo_object_fit }};
    --footer-pt:       {{ section.settings.footer_padding_top_mobile }}px;
    --name-size:       {{ section.settings.name_size_mobile }}px;
    --name-weight:     {{ section.settings.name_weight_desktop }};
    --name-color:      {{ section.settings.name_color_desktop }};
    --name-spacing:    {{ section.settings.name_spacing_desktop | times: 0.01 }}em;
    --name-transform:  {{ section.settings.name_transform_desktop }};
    --name-mb:         {{ section.settings.name_margin_bottom_desktop }}px;
    --price-size:      {{ section.settings.price_size_mobile }}px;
    --price-weight:    {{ section.settings.price_weight_desktop }};
    --price-color:     {{ section.settings.price_color_desktop }};
    --price-sale:      {{ section.settings.price_sale_color }};
    --pill-fs:         {{ section.settings.pill_font_size }}px;
    --pill-fw:         {{ section.settings.pill_font_weight }};
    --pill-br:         {{ section.settings.pill_border_radius }}px;
    --pill-pv:         {{ section.settings.pill_padding_v }}px;
    --pill-ph:         {{ section.settings.pill_padding_h }}px;
  }

  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} { --cols: 2; }
  }

  @media screen and (min-width: 1025px) {
    #shopify-section-{{ section.id }} {
      --pt:           {{ section.settings.padding_top_desktop }}px;
      --pb:           {{ section.settings.padding_bottom_desktop }}px;
      --ph:           {{ section.settings.padding_h_desktop }}px;
      --title-size:   {{ section.settings.title_size_desktop }}px;
      --cols:         {{ section.settings.desktop_columns }};
      --gap:          {{ section.settings.grid_gap_desktop }}px;
      --photo-aspect: {{ section.settings.photo_aspect_desktop }};
      --photo-radius: {{ section.settings.photo_radius_desktop }}px;
      --footer-pt:    {{ section.settings.footer_padding_top_desktop }}px;
      --name-size:    {{ section.settings.name_size_desktop }}px;
      --price-size:   {{ section.settings.price_size_desktop }}px;
    }
  }

  /* ── Section ── */
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg }};
    padding: var(--pt) var(--ph) var(--pb);
    font-family: '{{ mfont }}', sans-serif;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} * { box-sizing: border-box; }

  #shopify-section-{{ section.id }} .mtrl__wrap {
    max-width: {{ section.settings.desktop_max_width }}px;
    margin: 0 auto;
  }

  /* ── Section header ── */
  #shopify-section-{{ section.id }} .mtrl__hd-title {
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--title-size);
    font-weight: var(--title-weight);
    color: var(--title-color);
    letter-spacing: var(--title-spacing);
    text-transform: var(--title-transform);
    margin: 0 0 var(--title-mb);
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .mtrl__hd-desc {
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--desc-size);
    font-weight: var(--desc-weight);
    color: var(--desc-color);
    line-height: var(--desc-lh);
    max-width: var(--desc-max-w);
    margin: 0 0 var(--desc-mb);
  }

  #shopify-section-{{ section.id }} .mtrl__hd-divider {
    border: none;
    border-top: 1px solid var(--divider-color);
    margin: 0 0 var(--divider-mb);
  }

  #shopify-section-{{ section.id }} .mtrl__hd-sub {
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--sub-size);
    font-weight: var(--sub-weight);
    color: var(--sub-color);
    letter-spacing: var(--sub-spacing);
    text-transform: var(--sub-transform);
    margin: 0 0 var(--sub-mb);
  }

  /* ── Grid ── */
  #shopify-section-{{ section.id }} .mtrl__grid {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    gap: var(--gap);
  }

  /* ── Card ── */
  #shopify-section-{{ section.id }} .mtrl__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  /* ── Photo ── */
  #shopify-section-{{ section.id }} .mtrl__photo {
    position: relative;
    width: 100%;
    aspect-ratio: var(--photo-aspect);
    border-radius: var(--photo-radius);
    overflow: hidden;
    background-color: var(--photo-bg);
  }

  #shopify-section-{{ section.id }} .mtrl__photo-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--photo-fit);
  }

  /* ── Pill ── */
  #shopify-section-{{ section.id }} .mtrl__pill {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--pill-fs);
    font-weight: var(--pill-fw);
    border-radius: var(--pill-br);
    padding: var(--pill-pv) var(--pill-ph);
    line-height: 1.3;
    white-space: nowrap;
  }

  /* ── Footer ── */
  #shopify-section-{{ section.id }} .mtrl__footer {
    padding-top: var(--footer-pt);
  }

  /* ── Name ── */
  #shopify-section-{{ section.id }} .mtrl__name {
    display: block;
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--name-size);
    font-weight: var(--name-weight);
    color: var(--name-color);
    letter-spacing: var(--name-spacing);
    text-transform: var(--name-transform);
    margin: 0 0 var(--name-mb);
    line-height: 1.3;
  }

  /* ── Price ── */
  #shopify-section-{{ section.id }} .mtrl__price {
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .mtrl__price-current {
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--price-size);
    font-weight: var(--price-weight);
    color: var(--price-color);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .mtrl__price-current--sale {
    color: var(--price-sale);
  }

  #shopify-section-{{ section.id }} .mtrl__price-compare {
    font-family: '{{ mfont }}', sans-serif;
    font-size: var(--price-size);
    font-weight: var(--price-weight);
    color: #aaaaaa;
    text-decoration: line-through;
    line-height: 1.3;
  }
{%- endstyle -%}

{%- assign products_list = nil -%}
{%- if section.settings.collection_source == 'custom_collection' -%}
  {%- unless section.settings.custom_collection == blank -%}
    {%- assign products_list = collections[section.settings.custom_collection].products -%}
  {%- endunless -%}
{%- else -%}
  {%- if collection != blank -%}
    {%- assign products_list = collection.products -%}
  {%- endif -%}
{%- endif -%}

<div class="mtrl__wrap">

  <div class="mtrl__section-hd">
    {%- assign hd_title = section.settings.title_text -%}
    {%- if section.settings.collection_source == 'current_collection' and collection != blank and collection.title != blank -%}
      {%- assign hd_title = collection.title -%}
    {%- endif -%}
    {%- if hd_title != blank -%}
      <h2 class="mtrl__hd-title">{{ hd_title | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.show_description and section.settings.desc_text != blank -%}
      <p class="mtrl__hd-desc">{{ section.settings.desc_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.show_divider -%}
      <hr class="mtrl__hd-divider">
    {%- endif -%}

    {%- if section.settings.show_sub_label and section.settings.sub_label_text != blank -%}
      <p class="mtrl__hd-sub">{{ section.settings.sub_label_text | escape }}</p>
    {%- endif -%}
  </div>

  {%- if products_list != blank -%}
    <div class="mtrl__grid">
      {%- for product in products_list limit: section.settings.products_to_show -%}
        {%- assign block_data = section.blocks[forloop.index0] -%}
        {%- assign img_loading = 'lazy' -%}
        {%- if forloop.first -%}{%- assign img_loading = 'eager' -%}{%- endif -%}
        {%- assign card_name = product.title -%}
        {%- if block_data != blank and block_data.settings.custom_name != blank -%}
          {%- assign card_name = block_data.settings.custom_name -%}
        {%- endif -%}
        {%- assign on_sale = false -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign on_sale = true -%}
        {%- endif -%}
        <a href="{{ product.url }}" class="mtrl__card">
          <div class="mtrl__photo">
            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  class: 'mtrl__photo-img',
                  loading: img_loading,
                  alt: product.title,
                  widths: '400, 600, 800'
              }}
            {%- endif -%}
            {%- if block_data != blank and block_data.settings.show_pill and block_data.settings.pill_text != blank -%}
              <span
                class="mtrl__pill"
                style="background-color: {{ block_data.settings.pill_bg }}; color: {{ block_data.settings.pill_text_color }};"
              >{{ block_data.settings.pill_text | escape }}</span>
            {%- endif -%}
          </div>
          <div class="mtrl__footer">
            <span class="mtrl__name">{{ card_name | escape }}</span>
            <div class="mtrl__price">
              {%- if on_sale -%}
                <span class="mtrl__price-compare">{{ product.compare_at_price | money_without_currency }}</span>
                <span class="mtrl__price-current mtrl__price-current--sale">{{ product.price | money_without_currency }}</span>
              {%- else -%}
                <span class="mtrl__price-current">{{ product.price | money_without_currency }}</span>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "MT-RELATED-BL",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Lettertype"
    },
    {
      "type": "text",
      "id": "font_family",
      "label": "Google Font naam",
      "default": "Poppins"
    },
    {
      "type": "header",
      "content": "Sectie header"
    },
    {
      "type": "text",
      "id": "title_text",
      "label": "Titel tekst",
      "default": "GEZICHT"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titel kleur",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte desktop",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte mobiel",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Titel gewicht",
      "options": [
        { "value": "300", "label": "300 — Light" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "500", "label": "500 — Medium" },
        { "value": "600", "label": "600 — Semi Bold" },
        { "value": "700", "label": "700 — Bold" },
        { "value": "800", "label": "800 — Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
