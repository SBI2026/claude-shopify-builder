      "default": "auto"
    },
    {
      "type": "select",
      "id": "image_object_fit",
      "label": "Foto vulling",
      "options": [
        { "value": "cover",   "label": "Bijsnijden (cover)" },
        { "value": "contain", "label": "Passend (contain)" }
