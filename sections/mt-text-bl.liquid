    {
      "type": "range",
      "id": "padding_h",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding links/rechts",
      "default": 40
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "label": "Maximale breedte sectie",
      "default": 1400
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Label tonen",
      "default": false
