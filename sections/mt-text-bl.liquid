      "default": "center"
    },
    {
      "type": "header",
      "content": "Sectie stijl"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Achtergrond kleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
