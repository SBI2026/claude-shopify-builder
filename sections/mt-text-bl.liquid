{%- assign mfont = section.settings.font_family | default: 'Poppins' -%}
{%- assign mfont_url = mfont | replace: ' ', '+' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family={{ mfont_url }}:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- style -%}
  #MT-TB-{{ section.id }} {
    background-color: {{ section.settings.section_bg }};
    padding: 40px 20px;
    font-family: '{{ mfont }}', sans-serif;
  }

  @media screen and (min-width: 768px) {
    #MT-TB-{{ section.id }} {
      padding: {{ section.settings.padding_top }}px {{ section.settings.padding_h }}px {{ section.settings.padding_bottom }}px;
    }
  }

  #MT-TB-{{ section.id }} * { box-sizing: border-box; }

  /* ── OUTER WRAPPER ── */
  #MT-TB-{{ section.id }} .mttb__wrap {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── GRID ── */
  #MT-TB-{{ section.id }} .mttb__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap }}px;
    align-items: {{ section.settings.grid_align }};
  }

  @media screen and (min-width: 768px) {
    #MT-TB-{{ section.id }} .mttb__grid {
      grid-template-columns: {{ section.settings.grid_columns }};
    }
  }

  /* ── IMAGE POSITION ── */
  {%- if section.settings.image_position == 'right' -%}
  @media screen and (min-width: 768px) {
    #MT-TB-{{ section.id }} .mttb__image-col { order: 2; }
    #MT-TB-{{ section.id }} .mttb__text-col  { order: 1; }
  }
  {%- endif -%}

  /* ── IMAGE COLUMN ── */
  #MT-TB-{{ section.id }} .mttb__image-col { order: -1; }

  @media screen and (min-width: 768px) {
    #MT-TB-{{ section.id }} .mttb__image-col { order: unset; }
  }

  #MT-TB-{{ section.id }} .mttb__image-wrap {
    width: 100%;
    border-radius: {{ section.settings.image_border_radius }}px;
    overflow: hidden;
    background-color: {{ section.settings.image_placeholder_color }};
    {%- unless section.settings.image_aspect_ratio == 'auto' -%}
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    {%- endunless -%}
  }

  #MT-TB-{{ section.id }} .mttb__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.image_object_fit }};
    {%- unless section.settings.image_aspect_ratio == 'auto' -%}
    position: absolute;
    inset: 0;
    {%- endunless -%}
  }

  {%- unless section.settings.image_aspect_ratio == 'auto' -%}
  #MT-TB-{{ section.id }} .mttb__image-wrap {
    position: relative;
  }
  {%- endunless -%}

  /* ── LABEL ── */
  #MT-TB-{{ section.id }} .mttb__label {
    display: block;
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.label_font_size }}px;
    font-weight: {{ section.settings.label_font_weight }};
    color: {{ section.settings.label_color }};
    letter-spacing: {{ section.settings.label_letter_spacing | times: 0.01 }}em;
    {%- if section.settings.label_uppercase -%}text-transform: uppercase;{%- endif -%}
    margin-bottom: {{ section.settings.label_margin_bottom }}px;
    line-height: 1.4;
  }

  /* ── TITLE ── */
  #MT-TB-{{ section.id }} .mttb__title {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.title_font_size_mobile }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    line-height: {{ section.settings.title_line_height }};
    letter-spacing: {{ section.settings.title_letter_spacing }};
    margin: 0 0 {{ section.settings.title_margin_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-TB-{{ section.id }} .mttb__title {
      font-size: {{ section.settings.title_font_size_desktop }}px;
    }
  }

  /* ── BODY ── */
  #MT-TB-{{ section.id }} .mttb__body {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.body_font_size }}px;
    font-weight: {{ section.settings.body_font_weight }};
    color: {{ section.settings.body_color }};
    line-height: {{ section.settings.body_line_height }};
    max-width: {{ section.settings.body_max_width }}px;
    margin: 0 0 {{ section.settings.body_margin_bottom }}px;
  }

  /* ── BUTTON ── */
  #MT-TB-{{ section.id }} .mttb__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease, opacity 0.15s ease;
    line-height: 1;
    border-radius: {{ section.settings.button_border_radius }}px;

    {%- if section.settings.button_style == 'filled' -%}
      background-color: {{ section.settings.button_bg }};
      color: {{ section.settings.button_color }};
      border: 2px solid {{ section.settings.button_bg }};
      padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    {%- elsif section.settings.button_style == 'outline' -%}
      background-color: transparent;
      color: {{ section.settings.button_border_color }};
      border: 2px solid {{ section.settings.button_border_color }};
      padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    {%- else -%}
      background-color: transparent;
      color: {{ section.settings.button_color }};
      border: none;
      padding: 0;
      text-decoration: underline;
      text-underline-offset: 3px;
    {%- endif -%}
  }

  #MT-TB-{{ section.id }} .mttb__btn:hover {
    {%- if section.settings.button_style == 'filled' -%}
      background-color: {{ section.settings.button_hover_bg }};
      color: {{ section.settings.button_hover_color }};
      border-color: {{ section.settings.button_hover_bg }};
    {%- elsif section.settings.button_style == 'outline' -%}
      background-color: {{ section.settings.button_border_color }};
      color: {{ section.settings.button_hover_color }};
    {%- else -%}
      opacity: 0.65;
    {%- endif -%}
  }

  @media screen and (max-width: 767px) {
    #MT-TB-{{ section.id }} .mttb__btn--full {
      display: block;
      width: 100%;
      text-align: center;
    }
  }
{%- endstyle -%}

{%- assign img_alt = section.settings.title_text | escape -%}
{%- assign btn_classes = 'mttb__btn' -%}
{%- if section.settings.button_full_width_mobile -%}
  {%- assign btn_classes = 'mttb__btn mttb__btn--full' -%}
{%- endif -%}

<div id="MT-TB-{{ section.id }}">
  <div class="mttb__wrap">
    <div class="mttb__grid">

      {%- comment -%} ── IMAGE COLUMN ── {%- endcomment -%}
      <div class="mttb__image-col">
        <div class="mttb__image-wrap">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1400
              | image_tag:
                class: 'mttb__img',
                loading: 'lazy',
                alt: img_alt,
                widths: '600, 800, 1000, 1200, 1400'
            }}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── TEXT COLUMN ── {%- endcomment -%}
      <div class="mttb__text-col">

        {%- if section.settings.show_label and section.settings.label_text != blank -%}
          <span class="mttb__label">{{ section.settings.label_text | escape }}</span>
        {%- endif -%}

        {%- if section.settings.title_text != blank -%}
          <h2 class="mttb__title">{{ section.settings.title_text | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <p class="mttb__body">{{ section.settings.body_text | escape }}</p>
        {%- endif -%}

        {%- if section.settings.show_button and section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_url | default: '/' }}" class="{{ btn_classes }}">
            {{ section.settings.button_text | escape }}
          </a>
        {%- endif -%}

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "MT-TEXT-BL",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
