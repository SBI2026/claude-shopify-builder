      "default": "cover"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Foto afronding (px)",
      "default": 16
    },
    {
      "type": "color",
      "id": "image_placeholder_color",
      "label": "Placeholder kleur (geen foto)",
      "default": "#f5f4f0"
    },
    {
      "type": "header",
      "content": "Lay-out"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Foto positie",
      "options": [
        { "value": "left",  "label": "Links" },
        { "value": "right", "label": "Rechts" }
