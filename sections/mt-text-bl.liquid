    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Foto verhouding",
      "options": [
        { "value": "auto",  "label": "Automatisch" },
        { "value": "1/1",   "label": "1:1 (vierkant)" },
        { "value": "3/4",   "label": "3:4 (portret)" },
        { "value": "4/3",   "label": "4:3 (landschap)" },
        { "value": "16/9",  "label": "16:9 (breed)" }
