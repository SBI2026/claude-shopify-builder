{%- assign mfont = section.settings.font_family -%}
{%- assign mfont_bold = mfont | font_modify: 'weight', 'bold' -%}
{%- assign ov_opacity = section.settings.hero_overlay_opacity | divided_by: 100.0 -%}

{%- comment -%} Build accent heading HTML {%- endcomment -%}
{%- assign heading_html_out = '' -%}
{%- if section.settings.heading != blank -%}
  {%- assign accent_raw = section.settings.accent_words | split: ',' -%}
  {%- assign accent_joined = '' -%}
  {%- for aw in accent_raw -%}
    {%- assign aw_clean = aw | strip | downcase -%}
    {%- if forloop.first -%}
      {%- assign accent_joined = aw_clean -%}
    {%- else -%}
      {%- assign accent_joined = accent_joined | append: '~~' | append: aw_clean -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign accent_list = accent_joined | split: '~~' -%}
  {%- assign h_words = section.settings.heading | split: ' ' -%}
  {%- capture heading_html_out -%}
    {%- for hw in h_words -%}
      {%- assign hw_base = hw | downcase | remove: ',' | remove: '.' | remove: '!' | remove: '?' | remove: ':' | remove: ';' -%}
      {%- assign hw_accent = false -%}
      {%- for aw in accent_list -%}
        {%- if hw_base == aw -%}{%- assign hw_accent = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if hw_accent -%}<span class="mtah__accent">{{ hw | escape }}</span>{%- else -%}{{ hw | escape }}{%- endif -%}{% unless forloop.last %} {% endunless %}
    {%- endfor -%}
  {%- endcapture -%}
{%- endif -%}

{%- style -%}
  {{ mfont | font_face }}
  {%- if mfont_bold -%}{{ mfont_bold | font_face }}{%- endif -%}

  #MT-AH-{{ section.id }} {
    font-family: {{ mfont.family }}, sans-serif;
  }

  #MT-AH-{{ section.id }} * { box-sizing: border-box; }

  /* ══════════════════════
     PART 1 — HERO
  ══════════════════════ */
  #MT-AH-{{ section.id }} .mtah__hero {
    position: relative;
    width: calc(100% - {{ section.settings.hero_margin | times: 1 }}px);
    margin-left: {{ section.settings.hero_margin | divided_by: 2 | round: 0 }}px;
    margin-right: {{ section.settings.hero_margin | divided_by: 2 | round: 0 }}px;
    height: {{ section.settings.hero_height | times: 0.65 | round: 0 }}px;
    border-radius: {{ section.settings.hero_border_radius }}px;
    overflow: hidden;
    background-color: #111111;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__hero {
      width: calc(100% - {{ section.settings.hero_margin | times: 2 }}px);
      margin-left: {{ section.settings.hero_margin }}px;
      margin-right: {{ section.settings.hero_margin }}px;
      height: {{ section.settings.hero_height }}px;
    }
  }

  #MT-AH-{{ section.id }} .mtah__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #MT-AH-{{ section.id }} .mtah__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, {{ ov_opacity }});
    z-index: 1;
  }

  #MT-AH-{{ section.id }} .mtah__hero-title {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    font-family: {{ mfont.family }}, sans-serif;
    font-size: 36px;
    font-weight: {{ section.settings.hero_title_weight }};
    color: {{ section.settings.hero_title_color }};
    letter-spacing: {{ section.settings.hero_title_spacing }}px;
    text-align: center;
    margin: 0;
    white-space: nowrap;
    line-height: 1.1;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__hero-title {
      font-size: {{ section.settings.hero_title_size }}px;
    }
  }

  /* ══════════════════════
     PART 2 — CONTENT
  ══════════════════════ */
  #MT-AH-{{ section.id }} .mtah__content {
    background-color: {{ section.settings.content_bg }};
    padding: 32px 20px;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__content {
      padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_h }}px {{ section.settings.content_padding_bottom }}px;
    }
  }

  /* ── Label pill ── */
  #MT-AH-{{ section.id }} .mtah__label {
    display: inline-block;
    background-color: {{ section.settings.label_bg }};
    border: 0.5px solid #e0e0e0;
    border-radius: {{ section.settings.label_border_radius }}px;
    font-family: {{ mfont.family }}, sans-serif;
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    color: {{ section.settings.label_color }};
    padding: 6px 14px;
    margin-bottom: {{ section.settings.label_margin_bottom }}px;
    line-height: 1.4;
  }

  /* ── Heading (CHANGE 1: full width) ── */
  #MT-AH-{{ section.id }} .mtah__heading {
    font-family: {{ mfont.family }}, sans-serif;
    font-size: 24px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    line-height: {{ section.settings.heading_line_height }};
    max-width: 100%;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__heading {
      font-size: {{ section.settings.heading_size }}px;
    }
  }

  #MT-AH-{{ section.id }} .mtah__accent {
    color: {{ section.settings.accent_color }};
  }

  /* ── Product cards grid (CHANGE 2) ── */
  #MT-AH-{{ section.id }} .mtah__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.cards_gap }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__cards {
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }
  }

  /* ── Card link wrapper ── */
  #MT-AH-{{ section.id }} .mtah__card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
  }

  /* ── Photo area ── */
  #MT-AH-{{ section.id }} .mtah__card-photo {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  #MT-AH-{{ section.id }} .mtah__card-photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Number overlay ── */
  #MT-AH-{{ section.id }} .mtah__card-number {
    position: absolute;
    top: 16px;
    left: 16px;
    z-index: 2;
    font-family: {{ mfont.family }}, sans-serif;
    line-height: 1;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    pointer-events: none;
  }

  /* ── Card footer ── */
  #MT-AH-{{ section.id }} .mtah__card-footer {
    padding: 14px 0 0;
    text-align: center;
  }

  #MT-AH-{{ section.id }} .mtah__card-name {
    font-family: {{ mfont.family }}, sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 6px;
    line-height: 1.3;
  }

  #MT-AH-{{ section.id }} .mtah__card-line {
    display: block;
    width: 32px;
    height: 1px;
    margin: 6px auto;
  }

  #MT-AH-{{ section.id }} .mtah__card-subtitle {
    display: block;
    font-family: {{ mfont.family }}, sans-serif;
    font-weight: 400;
    text-align: center;
    line-height: 1.4;
  }
{%- endstyle -%}

<div id="MT-AH-{{ section.id }}">

  {%- comment -%} ══ PART 1: HERO BANNER ══ {%- endcomment -%}
  <div class="mtah__hero">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2000
        | image_tag:
          class: 'mtah__hero-img',
          loading: 'eager',
          alt: section.settings.hero_title,
          widths: '800, 1200, 1600, 2000'
      }}
    {%- endif -%}
    <div class="mtah__overlay"></div>
    {%- if section.settings.hero_title != blank -%}
      <h1 class="mtah__hero-title">{{ section.settings.hero_title | escape }}</h1>
    {%- endif -%}
  </div>

  {%- comment -%} ══ PART 2: CONTENT SECTION ══ {%- endcomment -%}
  <div class="mtah__content">

    {%- if section.settings.label_text != blank -%}
      <span class="mtah__label">{{ section.settings.label_text | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="mtah__heading">{{ heading_html_out }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mtah__cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' -%}

            {%- comment -%} Resolve link URL {%- endcomment -%}
            {%- assign card_url = '#' -%}
            {%- if block.settings.product != blank -%}
              {%- assign card_url = block.settings.product.url -%}
            {%- endif -%}

            <a
              href="{{ card_url }}"
              class="mtah__card"
              style="border-radius: {{ block.settings.card_border_radius }}px;"
              {{ block.shopify_attributes }}
            >

              {%- comment -%} Photo {%- endcomment -%}
              <div class="mtah__card-photo" style="background-color: {{ block.settings.photo_bg }};">

                {%- if block.settings.custom_image != blank -%}
                  {{
                    block.settings.custom_image
                    | image_url: width: 600
                    | image_tag:
                      class: 'mtah__card-photo-img',
                      loading: 'lazy',
                      alt: block.settings.card_title,
                      widths: '300, 450, 600'
                  }}
                {%- elsif block.settings.product != blank and block.settings.product.featured_image != blank -%}
                  {{
                    block.settings.product.featured_image
                    | image_url: width: 600
                    | image_tag:
                      class: 'mtah__card-photo-img',
                      loading: 'lazy',
                      alt: block.settings.product.title,
                      widths: '300, 450, 600'
                  }}
                {%- endif -%}

                {%- if block.settings.number != blank -%}
                  <span
                    class="mtah__card-number"
                    style="font-size: {{ block.settings.number_size }}px; font-weight: {{ block.settings.number_weight }}; color: {{ block.settings.number_color }};"
                  >{{ block.settings.number | escape }}</span>
                {%- endif -%}

              </div>

              {%- comment -%} Footer {%- endcomment -%}
              <div class="mtah__card-footer">

                {%- assign display_name = block.settings.card_title -%}
                {%- if block.settings.product != blank and block.settings.product.title != blank -%}
                  {%- assign display_name = block.settings.product.title -%}
                {%- endif -%}
                {%- if display_name != blank -%}
                  <p
                    class="mtah__card-name"
                    style="font-size: {{ block.settings.title_size }}px; font-weight: {{ block.settings.title_weight }}; color: {{ block.settings.title_color }};"
                  >{{ display_name | escape }}</p>
                {%- endif -%}

                <span class="mtah__card-line" style="background-color: {{ block.settings.line_color }};"></span>

                {%- if block.settings.card_subtitle != blank -%}
                  <span
                    class="mtah__card-subtitle"
                    style="font-size: {{ block.settings.subtitle_size }}px; color: {{ block.settings.subtitle_color }};"
                  >{{ block.settings.card_subtitle | escape }}</span>
                {%- endif -%}

              </div>

            </a>

          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

</div>

