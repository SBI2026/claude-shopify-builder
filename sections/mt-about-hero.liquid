{%- assign mfont = section.settings.font_family | default: 'Poppins' -%}
{%- assign mfont_url = mfont | replace: ' ', '+' -%}
{%- assign ov_opacity = section.settings.hero_overlay_opacity | divided_by: 100.0 -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family={{ mfont_url }}:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- comment -%} Build accent heading HTML {%- endcomment -%}
{%- assign heading_html_out = '' -%}
{%- if section.settings.heading != blank -%}
  {%- assign accent_raw = section.settings.accent_words | split: ',' -%}
  {%- assign accent_joined = '' -%}
  {%- for aw in accent_raw -%}
    {%- assign aw_clean = aw | strip | downcase -%}
    {%- if forloop.first -%}
      {%- assign accent_joined = aw_clean -%}
    {%- else -%}
      {%- assign accent_joined = accent_joined | append: '~~' | append: aw_clean -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign accent_list = accent_joined | split: '~~' -%}
  {%- assign h_words = section.settings.heading | split: ' ' -%}
  {%- capture heading_html_out -%}
    {%- for hw in h_words -%}
      {%- assign hw_base = hw | downcase | remove: ',' | remove: '.' | remove: '!' | remove: '?' | remove: ':' | remove: ';' -%}
      {%- assign hw_accent = false -%}
      {%- for aw in accent_list -%}
        {%- if hw_base == aw -%}{%- assign hw_accent = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if hw_accent -%}<span class="mtah__accent">{{ hw | escape }}</span>{%- else -%}{{ hw | escape }}{%- endif -%}{% unless forloop.last %} {% endunless %}
    {%- endfor -%}
  {%- endcapture -%}
{%- endif -%}

{%- style -%}
  #MT-AH-{{ section.id }} {
    font-family: '{{ mfont }}', sans-serif;
  }

  #MT-AH-{{ section.id }} * { box-sizing: border-box; }

  /* ══════════════════════
     PART 1 — HERO
  ══════════════════════ */
  #MT-AH-{{ section.id }} .mtah__hero {
    position: relative;
    width: calc(100% - {{ section.settings.hero_margin | times: 1 }}px);
    margin-left: {{ section.settings.hero_margin | divided_by: 2 | round: 0 }}px;
    margin-right: {{ section.settings.hero_margin | divided_by: 2 | round: 0 }}px;
    height: {{ section.settings.hero_height | times: 0.65 | round: 0 }}px;
    border-radius: {{ section.settings.hero_border_radius }}px;
    overflow: hidden;
    background-color: #111111;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__hero {
      width: calc(100% - {{ section.settings.hero_margin | times: 2 }}px);
      margin-left: {{ section.settings.hero_margin }}px;
      margin-right: {{ section.settings.hero_margin }}px;
      height: {{ section.settings.hero_height }}px;
    }
  }

  #MT-AH-{{ section.id }} .mtah__hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #MT-AH-{{ section.id }} .mtah__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, {{ ov_opacity }});
    z-index: 1;
  }

  #MT-AH-{{ section.id }} .mtah__hero-title {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    font-family: '{{ mfont }}', sans-serif;
    font-size: 36px;
    font-weight: {{ section.settings.hero_title_weight }};
    color: {{ section.settings.hero_title_color }};
    letter-spacing: {{ section.settings.hero_title_spacing }}px;
    text-align: center;
    margin: 0;
    white-space: nowrap;
    line-height: 1.1;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__hero-title {
      font-size: {{ section.settings.hero_title_size }}px;
    }
  }

  /* ══════════════════════
     PART 2 — CONTENT
  ══════════════════════ */
  #MT-AH-{{ section.id }} .mtah__content {
    background-color: {{ section.settings.content_bg }};
    padding: 32px 20px;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__content {
      padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_h }}px {{ section.settings.content_padding_bottom }}px;
    }
  }

  /* ── Label pill ── */
  #MT-AH-{{ section.id }} .mtah__label {
    display: inline-block;
    background-color: {{ section.settings.label_bg }};
    border: 0.5px solid #e0e0e0;
    border-radius: {{ section.settings.label_border_radius }}px;
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    color: {{ section.settings.label_color }};
    padding: 6px 14px;
    margin-bottom: {{ section.settings.label_margin_bottom }}px;
    line-height: 1.4;
  }

  /* ── Heading ── */
  #MT-AH-{{ section.id }} .mtah__heading {
    font-family: '{{ mfont }}', sans-serif;
    font-size: 24px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    line-height: {{ section.settings.heading_line_height }};
    max-width: {{ section.settings.heading_max_width }}px;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__heading {
      font-size: {{ section.settings.heading_size }}px;
    }
  }

  #MT-AH-{{ section.id }} .mtah__accent {
    color: {{ section.settings.accent_color }};
  }

  /* ── Cards grid ── */
  #MT-AH-{{ section.id }} .mtah__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.cards_gap }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-AH-{{ section.id }} .mtah__cards {
      grid-template-columns: repeat({{ section.settings.cards_columns }}, 1fr);
    }
  }

  /* ── Card base ── */
  #MT-AH-{{ section.id }} .mtah__card {
    border: 0.5px solid #e8e8e4;
    display: flex;
    flex-direction: column;
  }

  /* ── Per-block card overrides ── */
  {%- for block in section.blocks -%}
    {%- if block.type == 'feature_card' -%}
    #MT-AH-{{ section.id }} .mtah__card--{{ block.id }} {
      background-color: {{ block.settings.card_bg }};
      border-radius: {{ block.settings.card_border_radius }}px;
      padding: {{ block.settings.card_padding }}px;
      min-height: {{ block.settings.card_min_height }}px;
    }
    {%- endif -%}
  {%- endfor -%}

  /* ── Card icon ── */
  #MT-AH-{{ section.id }} .mtah__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    flex-shrink: 0;
    align-self: flex-start;
  }

  #MT-AH-{{ section.id }} .mtah__icon-img {
    display: block;
    object-fit: cover;
  }

  /* ── Card text ── */
  #MT-AH-{{ section.id }} .mtah__card-title {
    font-family: '{{ mfont }}', sans-serif;
    margin: 0;
    line-height: 1.2;
  }

  #MT-AH-{{ section.id }} .mtah__card-desc {
    font-family: '{{ mfont }}', sans-serif;
    font-weight: 400;
    line-height: 1.65;
    margin: 0;
  }
{%- endstyle -%}

<div id="MT-AH-{{ section.id }}">

  {%- comment -%} ══ PART 1: HERO BANNER ══ {%- endcomment -%}
  <div class="mtah__hero">
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2000
        | image_tag:
          class: 'mtah__hero-img',
          loading: 'eager',
          alt: section.settings.hero_title,
          widths: '800, 1200, 1600, 2000'
      }}
    {%- endif -%}
    <div class="mtah__overlay"></div>
    {%- if section.settings.hero_title != blank -%}
      <h1 class="mtah__hero-title">{{ section.settings.hero_title | escape }}</h1>
    {%- endif -%}
  </div>

  {%- comment -%} ══ PART 2: CONTENT SECTION ══ {%- endcomment -%}
  <div class="mtah__content">

    {%- if section.settings.label_text != blank -%}
      <span class="mtah__label">{{ section.settings.label_text | escape }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="mtah__heading">{{ heading_html_out }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mtah__cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_card' -%}
            <div class="mtah__card mtah__card--{{ block.id }}" {{ block.shopify_attributes }}>

              {%- comment -%} Icon {%- endcomment -%}
              {%- if block.settings.icon_image != blank -%}
                <div
                  class="mtah__icon-wrap"
                  style="background-color: {{ block.settings.icon_bg }}; border-radius: {{ block.settings.icon_radius }}px; width: {{ block.settings.icon_size | plus: 24 }}px; height: {{ block.settings.icon_size | plus: 24 }}px; margin-bottom: {{ block.settings.icon_margin_bottom }}px;"
                >
                  {{
                    block.settings.icon_image
                    | image_url: width: 192
                    | image_tag:
                      class: 'mtah__icon-img',
                      loading: 'lazy',
                      alt: block.settings.card_title,
                      widths: '48, 96, 192',
                      style: "width: " | append: block.settings.icon_size | append: "px; height: " | append: block.settings.icon_size | append: "px; border-radius: " | append: block.settings.icon_radius | append: "px;"
                  }}
                </div>
              {%- endif -%}

              {%- comment -%} Title {%- endcomment -%}
              {%- if block.settings.card_title != blank -%}
                <p
                  class="mtah__card-title"
                  style="font-size: {{ block.settings.card_title_size }}px; font-weight: {{ block.settings.card_title_weight }}; color: {{ block.settings.card_title_color }}; margin-bottom: {{ block.settings.card_title_margin_bottom }}px;"
                >{{ block.settings.card_title | escape }}</p>
              {%- endif -%}

              {%- comment -%} Description {%- endcomment -%}
              {%- if block.settings.card_desc != blank -%}
                <p
                  class="mtah__card-desc"
                  style="font-size: {{ block.settings.card_desc_size }}px; color: {{ block.settings.card_desc_color }};"
                >{{ block.settings.card_desc | escape }}</p>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

</div>

