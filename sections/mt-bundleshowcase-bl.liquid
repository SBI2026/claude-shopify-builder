{% assign ai_gen_id = section.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bundle-showcase-{{ ai_gen_id }} {
    display: block;
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_mobile }}px {{ section.settings.padding_mobile | times: 0.5 }}px;
    width: {{ section.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-bundle-showcase-{{ ai_gen_id }} {
      padding: {{ section.settings.padding_desktop }}px {{ section.settings.padding_desktop | times: 0.7 }}px;
    }
  }

  .ai-bundle-showcase-container-{{ ai_gen_id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-bundle-showcase-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ section.settings.header_margin_bottom }}px;
  }

  .ai-bundle-showcase-eyebrow-{{ ai_gen_id }} {
    font-size: {{ section.settings.eyebrow_font_size }}px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.eyebrow_color }};
    margin-bottom: {{ section.settings.eyebrow_margin_bottom }}px;
  }

  .ai-bundle-showcase-heading-{{ ai_gen_id }} {
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    font-weight: 300;
    color: {{ section.settings.heading_color }};
    line-height: 1.2;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-bundle-showcase-heading-{{ ai_gen_id }} {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }
  }

  .ai-bundle-showcase-subheading-{{ ai_gen_id }} {
    font-size: {{ section.settings.subheading_font_size }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0;
  }

  .ai-bundle-showcase-hero-card-{{ ai_gen_id }} {
    background-color: {{ section.settings.hero_card_bg }};
    border-radius: {{ section.settings.hero_card_radius }}px;
    padding: {{ section.settings.hero_card_padding_mobile }}px {{ section.settings.hero_card_padding_mobile | times: 0.8 }}px;
    margin-bottom: {{ section.settings.hero_card_margin_bottom }}px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .ai-bundle-showcase-hero-card-{{ ai_gen_id }} {
      flex-direction: row;
      align-items: stretch;
      padding: {{ section.settings.hero_card_padding_desktop }}px {{ section.settings.hero_card_padding_desktop | times: 1.1 }}px;
      gap: 40px;
    }
  }

  .ai-bundle-showcase-hero-images-{{ ai_gen_id }} {
    display: flex;
    justify-content: flex-start;
    align-items: stretch;
    flex: 1;
  }

  .ai-bundle-showcase-hero-img-desktop-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.product_image_radius }}px;
  }

  .ai-bundle-showcase-hero-img-mobile-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ section.settings.product_image_radius }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-bundle-showcase-hero-img-desktop-{{ ai_gen_id }} { display: block; }
    .ai-bundle-showcase-hero-img-mobile-{{ ai_gen_id }} { display: none; }
  }

  .ai-bundle-showcase-hero-img-desktop-{{ ai_gen_id }} img,
  .ai-bundle-showcase-hero-img-mobile-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ section.settings.product_image_radius }}px;
    display: block;
  }

  .ai-bundle-showcase-hero-img-desktop-{{ ai_gen_id }} .ai-bundle-showcase-hero-image-placeholder-{{ ai_gen_id }},
  .ai-bundle-showcase-hero-img-mobile-{{ ai_gen_id }} .ai-bundle-showcase-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 140px;
    background-color: #f4f4f4;
    border-radius: {{ section.settings.product_image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bundle-showcase-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-bundle-showcase-hero-info-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-bundle-showcase-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    border-radius: 999px;
    font-size: {{ section.settings.badge_font_size }}px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: {{ section.settings.badge_padding_v }}px {{ section.settings.badge_padding_h }}px;
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
  }

  .ai-bundle-showcase-product-name-{{ ai_gen_id }} {
    font-size: {{ section.settings.product_name_font_size }}px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ section.settings.product_name_color }};
    margin: 0 0 8px;
  }

  .ai-bundle-showcase-includes-{{ ai_gen_id }} {
    font-size: {{ section.settings.includes_font_size }}px;
    color: {{ section.settings.includes_color }};
    line-height: 1.6;
    margin: 0 0 {{ section.settings.includes_margin_bottom }}px;
  }

  .ai-bundle-showcase-price-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: {{ section.settings.price_margin_bottom }}px;
  }

  .ai-bundle-showcase-current-price-{{ ai_gen_id }} {
    font-size: {{ section.settings.current_price_font_size }}px;
    font-weight: 500;
    color: {{ section.settings.current_price_color }};
  }

  .ai-bundle-showcase-original-price-{{ ai_gen_id }} {
    font-size: {{ section.settings.original_price_font_size }}px;
    color: {{ section.settings.original_price_color }};
    text-decoration: line-through;
  }

  .ai-bundle-showcase-saving-badge-{{ ai_gen_id }} {
    background-color: {{ section.settings.saving_badge_bg }};
    color: {{ section.settings.saving_badge_color }};
    border: 0.5px solid {{ section.settings.saving_badge_border }};
    border-radius: 999px;
    font-size: {{ section.settings.saving_badge_font_size }}px;
    font-weight: 600;
    padding: {{ section.settings.saving_badge_padding_v }}px {{ section.settings.saving_badge_padding_h }}px;
  }

  .ai-bundle-showcase-usage-calc-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ section.settings.includes_color }};
    margin: -8px 0 12px;
    font-style: italic;
  }

  .ai-bundle-showcase-button-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_color }};
    border-radius: 999px;
    padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-bundle-showcase-button-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_hover_bg }};
  }

  .ai-bundle-showcase-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.grid_gap }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-bundle-showcase-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ai-bundle-showcase-card-{{ ai_gen_id }} {
    background-color: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_padding }}px {{ section.settings.card_padding | times: 0.9 }}px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
  }

  .ai-bundle-showcase-card-{{ ai_gen_id }} > div:last-child {
    flex: 1;
  }

  .ai-bundle-showcase-card-images-{{ ai_gen_id }} {
    display: flex;
    justify-content: flex-start;
    flex-shrink: 0;
  }

  .ai-bundle-showcase-card-image-{{ ai_gen_id }} {
    width: {{ section.settings.card_image_size }}px;
    flex-shrink: 0;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: {{ section.settings.product_image_radius }}px;
  }

  .ai-bundle-showcase-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: {{ section.settings.product_image_radius }}px;
    display: block;
  }

  .ai-bundle-showcase-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: #f4f4f4;
    border-radius: {{ section.settings.product_image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-bundle-showcase-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-bundle-showcase-button-outline-{{ ai_gen_id }} {
    display: inline-block;
    background-color: transparent;
    color: {{ section.settings.button_outline_color }};
    border: {{ section.settings.button_outline_thickness }}px solid {{ section.settings.button_outline_border }};
    border-radius: 999px;
    padding: {{ section.settings.button_padding_v }}px {{ section.settings.button_padding_h }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-bundle-showcase-button-outline-{{ ai_gen_id }}:hover {
    background-color: {{ section.settings.button_outline_hover_bg }};
    color: {{ section.settings.button_outline_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-bundle-showcase-hero-images-{{ ai_gen_id }} {
      justify-content: center;
    }
    .ai-bundle-showcase-card-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
    }
    .ai-bundle-showcase-card-images-{{ ai_gen_id }} {
      justify-content: center;
    }
    .ai-bundle-showcase-card-image-{{ ai_gen_id }} {
      width: 100%;
      max-width: {{ section.settings.card_image_size }}px;
    }
  }
{% endstyle %}

<mt-bundleshowcase-{{ ai_gen_id }} class="ai-bundle-showcase-{{ ai_gen_id }}" {{ section.shopify_attributes }}>
  <div class="ai-bundle-showcase-container-{{ ai_gen_id }}">
    <div class="ai-bundle-showcase-header-{{ ai_gen_id }}">
      {% if section.settings.eyebrow_text != blank %}
        <div class="ai-bundle-showcase-eyebrow-{{ ai_gen_id }}">{{ section.settings.eyebrow_text }}</div>
      {% endif %}
      {% if section.settings.heading_text != blank %}
        <h2 class="ai-bundle-showcase-heading-{{ ai_gen_id }}">{{ section.settings.heading_text }}</h2>
      {% endif %}
      {% if section.settings.subheading_text != blank %}
        <p class="ai-bundle-showcase-subheading-{{ ai_gen_id }}">{{ section.settings.subheading_text }}</p>
      {% endif %}
    </div>

    <div class="ai-bundle-showcase-hero-card-{{ ai_gen_id }}">
      <div class="ai-bundle-showcase-hero-images-{{ ai_gen_id }}">
        <div class="ai-bundle-showcase-hero-img-desktop-{{ ai_gen_id }}">
          {% if section.settings.hero_product_image_1 %}
            <img
              src="{{ section.settings.hero_product_image_1 | image_url: width: 900 }}"
              alt="{{ section.settings.hero_product_image_1.alt | escape }}"
              loading="lazy"
              width="900"
              height="675"
            >
          {% else %}
            <div class="ai-bundle-showcase-hero-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <div class="ai-bundle-showcase-hero-img-mobile-{{ ai_gen_id }}">
          {% if section.settings.hero_product_image_mobile %}
            <img
              src="{{ section.settings.hero_product_image_mobile | image_url: width: 600 }}"
              alt="{{ section.settings.hero_product_image_mobile.alt | escape }}"
              loading="lazy"
              width="600"
              height="600"
            >
          {% else %}
            <div class="ai-bundle-showcase-hero-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-bundle-showcase-hero-info-{{ ai_gen_id }}">
        {% if section.settings.hero_badge_text != blank %}
          <span class="ai-bundle-showcase-badge-{{ ai_gen_id }}">{{ section.settings.hero_badge_text }}</span>
        {% endif %}
        {% if section.settings.hero_product_name != blank %}
          <h3 class="ai-bundle-showcase-product-name-{{ ai_gen_id }}">{{ section.settings.hero_product_name }}</h3>
        {% endif %}
        {% if section.settings.hero_includes_text != blank %}
          <p class="ai-bundle-showcase-includes-{{ ai_gen_id }}">{{ section.settings.hero_includes_text }}</p>
        {% endif %}
        <div class="ai-bundle-showcase-price-row-{{ ai_gen_id }}">
          {% if section.settings.hero_current_price != blank %}
            <span class="ai-bundle-showcase-current-price-{{ ai_gen_id }}">{{ section.settings.hero_current_price }}</span>
          {% endif %}
          {% if section.settings.hero_original_price != blank %}
            <span class="ai-bundle-showcase-original-price-{{ ai_gen_id }}">{{ section.settings.hero_original_price }}</span>
          {% endif %}
          {% if section.settings.hero_saving_text != blank %}
            <span class="ai-bundle-showcase-saving-badge-{{ ai_gen_id }}">{{ section.settings.hero_saving_text }}</span>
          {% endif %}
        </div>
        {% if section.settings.hero_show_usage_calc %}
          {% assign hero_usage_total = section.settings.hero_usage_price | times: 100 | round %}
          {% assign hero_usage_per_day = hero_usage_total | divided_by: section.settings.hero_usage_days %}
          {% assign hero_usage_euros = hero_usage_per_day | divided_by: 100 %}
          {% assign hero_usage_cents = hero_usage_per_day | modulo: 100 %}
          <p class="ai-bundle-showcase-usage-calc-{{ ai_gen_id }}">
            {{ section.settings.hero_usage_days }} dagen gebruiksduur — €{{ hero_usage_euros }},{{ hero_usage_cents | prepend: '0' | slice: -2, 2 }} per dag
          </p>
        {% endif %}
        {% if section.settings.hero_button_text != blank %}
          <a href="{{ section.settings.hero_button_link }}" class="ai-bundle-showcase-button-{{ ai_gen_id }}">
            {{ section.settings.hero_button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-bundle-showcase-grid-{{ ai_gen_id }}">
      <div class="ai-bundle-showcase-card-{{ ai_gen_id }}">
        <div class="ai-bundle-showcase-card-images-{{ ai_gen_id }}">
          <div class="ai-bundle-showcase-card-image-{{ ai_gen_id }}">
            {% if section.settings.bundle_2_product_image_1 %}
              <img
                src="{{ section.settings.bundle_2_product_image_1 | image_url: width: 400 }}"
                alt="{{ section.settings.bundle_2_product_image_1.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-bundle-showcase-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
        <div>
          {% if section.settings.bundle_2_product_name != blank %}
            <h3 class="ai-bundle-showcase-product-name-{{ ai_gen_id }}">{{ section.settings.bundle_2_product_name }}</h3>
          {% endif %}
          {% if section.settings.bundle_2_includes_text != blank %}
            <p class="ai-bundle-showcase-includes-{{ ai_gen_id }}">{{ section.settings.bundle_2_includes_text }}</p>
          {% endif %}
          <div class="ai-bundle-showcase-price-row-{{ ai_gen_id }}">
            {% if section.settings.bundle_2_current_price != blank %}
              <span class="ai-bundle-showcase-current-price-{{ ai_gen_id }}">{{ section.settings.bundle_2_current_price }}</span>
            {% endif %}
            {% if section.settings.bundle_2_original_price != blank %}
              <span class="ai-bundle-showcase-original-price-{{ ai_gen_id }}">{{ section.settings.bundle_2_original_price }}</span>
            {% endif %}
            {% if section.settings.bundle_2_saving_text != blank %}
              <span class="ai-bundle-showcase-saving-badge-{{ ai_gen_id }}">{{ section.settings.bundle_2_saving_text }}</span>
            {% endif %}
          </div>
          {% if section.settings.bundle_2_show_usage_calc %}
            {% assign b2_usage_total = section.settings.bundle_2_usage_price | times: 100 | round %}
            {% assign b2_usage_per_day = b2_usage_total | divided_by: section.settings.bundle_2_usage_days %}
            {% assign b2_usage_euros = b2_usage_per_day | divided_by: 100 %}
            {% assign b2_usage_cents = b2_usage_per_day | modulo: 100 %}
            <p class="ai-bundle-showcase-usage-calc-{{ ai_gen_id }}">
              {{ section.settings.bundle_2_usage_days }} dagen gebruiksduur — €{{ b2_usage_euros }},{{ b2_usage_cents | prepend: '0' | slice: -2, 2 }} per dag
            </p>
          {% endif %}
          {% if section.settings.bundle_2_button_text != blank %}
            <a href="{{ section.settings.bundle_2_button_link }}" class="ai-bundle-showcase-button-outline-{{ ai_gen_id }}">
              {{ section.settings.bundle_2_button_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="ai-bundle-showcase-card-{{ ai_gen_id }}">
        <div class="ai-bundle-showcase-card-images-{{ ai_gen_id }}">
          <div class="ai-bundle-showcase-card-image-{{ ai_gen_id }}">
            {% if section.settings.bundle_3_product_image_1 %}
              <img
                src="{{ section.settings.bundle_3_product_image_1 | image_url: width: 400 }}"
                alt="{{ section.settings.bundle_3_product_image_1.alt | escape }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-bundle-showcase-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        </div>
        <div>
          {% if section.settings.bundle_3_product_name != blank %}
            <h3 class="ai-bundle-showcase-product-name-{{ ai_gen_id }}">{{ section.settings.bundle_3_product_name }}</h3>
          {% endif %}
          {% if section.settings.bundle_3_includes_text != blank %}
            <p class="ai-bundle-showcase-includes-{{ ai_gen_id }}">{{ section.settings.bundle_3_includes_text }}</p>
          {% endif %}
          <div class="ai-bundle-showcase-price-row-{{ ai_gen_id }}">
            {% if section.settings.bundle_3_current_price != blank %}
              <span class="ai-bundle-showcase-current-price-{{ ai_gen_id }}">{{ section.settings.bundle_3_current_price }}</span>
            {% endif %}
            {% if section.settings.bundle_3_original_price != blank %}
              <span class="ai-bundle-showcase-original-price-{{ ai_gen_id }}">{{ section.settings.bundle_3_original_price }}</span>
            {% endif %}
            {% if section.settings.bundle_3_saving_text != blank %}
              <span class="ai-bundle-showcase-saving-badge-{{ ai_gen_id }}">{{ section.settings.bundle_3_saving_text }}</span>
            {% endif %}
          </div>
          {% if section.settings.bundle_3_show_usage_calc %}
            {% assign b3_usage_total = section.settings.bundle_3_usage_price | times: 100 | round %}
            {% assign b3_usage_per_day = b3_usage_total | divided_by: section.settings.bundle_3_usage_days %}
            {% assign b3_usage_euros = b3_usage_per_day | divided_by: 100 %}
            {% assign b3_usage_cents = b3_usage_per_day | modulo: 100 %}
            <p class="ai-bundle-showcase-usage-calc-{{ ai_gen_id }}">
              {{ section.settings.bundle_3_usage_days }} dagen gebruiksduur — €{{ b3_usage_euros }},{{ b3_usage_cents | prepend: '0' | slice: -2, 2 }} per dag
            </p>
          {% endif %}
          {% if section.settings.bundle_3_button_text != blank %}
            <a href="{{ section.settings.bundle_3_button_link }}" class="ai-bundle-showcase-button-outline-{{ ai_gen_id }}">
              {{ section.settings.bundle_3_button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</mt-bundleshowcase-{{ ai_gen_id }}>

<script>
  (function() {
    class MtBundleshowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('mt-bundleshowcase-{{ ai_gen_id }}', MtBundleshowcase{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "MT-BUNDLESHOWCASE-BL",
  "settings": [
    {
      "type": "header",
      "content": "Sectie header"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow tekst",
      "default": "Voordeel bundels"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Hoofdtekst",
      "default": "Bespaar tot 20% op de complete routine"
    },
    {
      "type": "text",
      "id": "subheading_text",
      "label": "Subtekst",
      "default": "Kies de set die bij jou past"
    },
    {
      "type": "header",
      "content": "Hero bundel (Signature Set)"
    },
    {
      "type": "text",
      "id": "hero_badge_text",
      "label": "Badge tekst",
      "default": "Meest gekozen"
    },
    {
      "type": "text",
      "id": "hero_product_name",
      "label": "Productnaam",
      "default": "SIGNATURE SET"
    },
    {
      "type": "text",
      "id": "hero_includes_text",
      "label": "Bevat tekst",
      "default": "Alle 4 stappen — Reinigen · Vernieuwen · Herstel · Bescherming"
    },
    {
      "type": "text",
      "id": "hero_current_price",
      "label": "Huidige prijs",
      "default": "€99,95"
    },
    {
      "type": "text",
      "id": "hero_original_price",
      "label": "Originele prijs",
      "default": "€124,94"
    },
    {
      "type": "text",
      "id": "hero_saving_text",
      "label": "Korting tekst",
      "default": "−20%"
    },
    {
      "type": "text",
      "id": "hero_button_text",
      "label": "Button tekst",
      "default": "Voeg toe aan winkelwagen"
    },
    {
      "type": "url",
      "id": "hero_button_link",
      "label": "Button link"
    },
