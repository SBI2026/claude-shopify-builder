{%- assign mfont = section.settings.font_family | default: 'Poppins' -%}
{%- assign mfont_url = mfont | replace: ' ', '+' -%}
{%- assign trust_r = section.settings.trust_bg | color_extract: 'red' -%}
{%- assign trust_g = section.settings.trust_bg | color_extract: 'green' -%}
{%- assign trust_b = section.settings.trust_bg | color_extract: 'blue' -%}
{%- assign trust_a = section.settings.trust_bg_opacity | divided_by: 100.0 -%}
{%- assign badge_r = section.settings.expert_badge_color | color_extract: 'red' -%}
{%- assign badge_g = section.settings.expert_badge_color | color_extract: 'green' -%}
{%- assign badge_b = section.settings.expert_badge_color | color_extract: 'blue' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family={{ mfont_url }}:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- style -%}
  #mthp-{{ section.id }},
  #mthp-{{ section.id }} * {
    box-sizing: border-box;
  }

  /* ── HERO AREA ── */
  #mthp-{{ section.id }} .mthp__area {
    background: {{ section.settings.section_bg }};
    padding: 32px 20px;
  }

  @media (min-width: 768px) {
    #mthp-{{ section.id }} .mthp__area {
      padding: {{ section.settings.padding_top }}px {{ section.settings.padding_h }}px {{ section.settings.padding_bottom }}px;
    }
  }

  #mthp-{{ section.id }} .mthp__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── GRID ── */
  #mthp-{{ section.id }} .mthp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }

  @media (min-width: 768px) {
    #mthp-{{ section.id }} .mthp__grid {
      grid-template-columns: 1fr 1fr;
      gap: {{ section.settings.grid_gap }}px;
    }
  }

  /* ── LEFT COLUMN ── */
  #mthp-{{ section.id }} .mthp__left {
    display: flex;
    flex-direction: column;
  }

  /* ── BREADCRUMB ── */
  #mthp-{{ section.id }} .mthp__crumb {
    font-family: '{{ mfont }}', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #888884;
    margin-bottom: 24px;
    line-height: 1.4;
  }

  #mthp-{{ section.id }} .mthp__crumb a {
    color: #888884;
    text-decoration: none;
  }

  #mthp-{{ section.id }} .mthp__crumb a:hover {
    color: #555550;
  }

  /* ── TITLE ── */
  #mthp-{{ section.id }} .mthp__title {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    letter-spacing: {{ section.settings.title_letter_spacing | times: 0.01 }}em;
    text-transform: {{ section.settings.title_transform }};
    line-height: 1.1;
    margin: 0 0 {{ section.settings.title_margin_bottom }}px;
    padding: 0;
  }

  @media (min-width: 768px) {
    #mthp-{{ section.id }} .mthp__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }
  }

  /* ── SUBTITLE ── */
  #mthp-{{ section.id }} .mthp__subtitle {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    color: {{ section.settings.subtitle_color }};
    line-height: {{ section.settings.subtitle_line_height }};
    max-width: {{ section.settings.subtitle_max_width }}px;
    margin: 0;
    padding: 0;
  }

  /* ── RIGHT COLUMN / IMAGE ── */
  #mthp-{{ section.id }} .mthp__img-wrap {
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    background: {{ section.settings.image_bg }};
    display: block;
    {%- unless section.settings.image_aspect == 'auto' -%}
    aspect-ratio: {{ section.settings.image_aspect }};
    {%- endunless -%}
  }

  #mthp-{{ section.id }} .mthp__img-wrap img {
    width: 100%;
    display: block;
    {%- if section.settings.image_aspect == 'auto' -%}
    height: auto;
    {%- else -%}
    height: 100%;
    object-fit: {{ section.settings.image_object_fit }};
    {%- endif -%}
  }

  #mthp-{{ section.id }} .mthp__img-placeholder {
    width: 100%;
    {%- if section.settings.image_aspect == 'auto' -%}
    aspect-ratio: 4 / 3;
    {%- else -%}
    aspect-ratio: {{ section.settings.image_aspect }};
    {%- endif -%}
    background: {{ section.settings.image_bg }};
    border-radius: {{ section.settings.image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #mthp-{{ section.id }} .mthp__img-placeholder svg {
    width: 64px;
    height: 64px;
    opacity: 0.2;
  }

  /* ── TRUST BAR ── */
  #mthp-{{ section.id }} .mthp__trust {
    background-color: rgba({{ trust_r }}, {{ trust_g }}, {{ trust_b }}, {{ trust_a }});
    padding: {{ section.settings.trust_padding }}px 40px;
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  #mthp-{{ section.id }} .mthp__trust-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    text-align: left;
  }

  #mthp-{{ section.id }} .mthp__trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: {{ section.settings.trust_icon_size }}px;
    height: {{ section.settings.trust_icon_size }}px;
  }

  #mthp-{{ section.id }} .mthp__trust-icon svg {
    width: {{ section.settings.trust_icon_size }}px;
    height: {{ section.settings.trust_icon_size }}px;
    color: {{ section.settings.trust_text_color }};
    fill: {{ section.settings.trust_text_color }};
    display: block;
    overflow: visible;
  }

  #mthp-{{ section.id }} .mthp__trust-icon svg path,
  #mthp-{{ section.id }} .mthp__trust-icon svg circle,
  #mthp-{{ section.id }} .mthp__trust-icon svg rect,
  #mthp-{{ section.id }} .mthp__trust-icon svg polyline,
  #mthp-{{ section.id }} .mthp__trust-icon svg polygon,
  #mthp-{{ section.id }} .mthp__trust-icon svg line {
    fill: {{ section.settings.trust_text_color }};
  }

  #mthp-{{ section.id }} .mthp__trust-text {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.trust_font_size }}px;
    font-weight: 400;
    color: {{ section.settings.trust_text_color }};
    line-height: 1.4;
    max-width: 200px;
  }

  /* ── EXPERT CARD ── */
  #mthp-{{ section.id }} .mthp__expert {
    background: {{ section.settings.expert_card_bg }};
    border: 1px solid {{ section.settings.expert_card_border }};
    border-radius: {{ section.settings.expert_card_radius }}px;
    padding: {{ section.settings.expert_card_padding }}px;
    margin-top: {{ section.settings.expert_card_margin_top }}px;
  }

  #mthp-{{ section.id }} .mthp__expert-stars {
    color: {{ section.settings.expert_star_color }};
    font-size: 20px;
    letter-spacing: 2px;
    margin-bottom: 12px;
    line-height: 1;
  }

  #mthp-{{ section.id }} .mthp__expert-review {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.expert_review_size }}px;
    font-weight: 400;
    color: {{ section.settings.expert_review_color }};
    line-height: 1.7;
    margin: 0 0 16px;
    padding: 0;
  }

  #mthp-{{ section.id }} .mthp__expert-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #mthp-{{ section.id }} .mthp__expert-photo {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
  }

  #mthp-{{ section.id }} .mthp__expert-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #mthp-{{ section.id }} .mthp__expert-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #mthp-{{ section.id }} .mthp__expert-name-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  #mthp-{{ section.id }} .mthp__expert-name {
    font-family: '{{ mfont }}', sans-serif;
    font-size: 15px;
    font-weight: 700;
    color: {{ section.settings.expert_name_color }};
    line-height: 1.2;
  }

  #mthp-{{ section.id }} .mthp__expert-badge {
    font-family: '{{ mfont }}', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: {{ section.settings.expert_badge_color }};
    background: rgba({{ badge_r }}, {{ badge_g }}, {{ badge_b }}, 0.12);
    padding: 2px 8px;
    border-radius: 100px;
    line-height: 1.6;
    white-space: nowrap;
  }

  #mthp-{{ section.id }} .mthp__expert-meta {
    font-family: '{{ mfont }}', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: {{ section.settings.expert_meta_color }};
    line-height: 1.4;
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {
    #mthp-{{ section.id }} .mthp__trust {
      flex-direction: column;
      gap: 20px;
      padding: {{ section.settings.trust_padding }}px 20px;
    }
    #mthp-{{ section.id }} .mthp__trust-item {
      text-align: left;
    }
  }
{%- endstyle -%}

<div id="mthp-{{ section.id }}">

  <div class="mthp__area">
    <div class="mthp__inner">
      <div class="mthp__grid">

        <div class="mthp__left">

          {%- if section.settings.show_breadcrumb -%}
            <nav class="mthp__crumb" aria-label="Breadcrumb">
              <a href="{{ section.settings.breadcrumb_home_url }}">{{ section.settings.breadcrumb_home_label | escape }}</a>
              <span> / </span>
              <span>{{ section.settings.breadcrumb_collection_label | escape }}</span>
            </nav>
          {%- endif -%}

          {%- if section.settings.title_text != blank -%}
            <h1 class="mthp__title">{{ section.settings.title_text | escape }}</h1>
          {%- endif -%}

          {%- if section.settings.show_subtitle and section.settings.subtitle_text != blank -%}
            <p class="mthp__subtitle">{{ section.settings.subtitle_text | escape }}</p>
          {%- endif -%}

          {%- if section.settings.show_expert_card -%}
            <div class="mthp__expert">
              {%- assign star_count = section.settings.expert_stars -%}
              {%- if star_count > 0 -%}
                <div class="mthp__expert-stars">
                  {%- for i in (1..star_count) -%}★{%- endfor -%}
                </div>
              {%- endif -%}

              {%- if section.settings.expert_review_text != blank -%}
                <p class="mthp__expert-review">{{ section.settings.expert_review_text | escape }}</p>
              {%- endif -%}

              <div class="mthp__expert-row">
                {%- if section.settings.expert_photo != blank -%}
                  <div class="mthp__expert-photo">
                    <img
                      src="{{ section.settings.expert_photo | image_url: width: 100 }}"
                      alt="{{ section.settings.expert_name | escape }}"
                      width="48"
                      height="48"
                      loading="lazy"
                    >
                  </div>
                {%- endif -%}
                <div class="mthp__expert-info">
                  <div class="mthp__expert-name-row">
                    {%- if section.settings.expert_name != blank -%}
                      <span class="mthp__expert-name">{{ section.settings.expert_name | escape }}</span>
                    {%- endif -%}
                    {%- if section.settings.expert_show_badge and section.settings.expert_badge_text != blank -%}
                      <span class="mthp__expert-badge">✓ {{ section.settings.expert_badge_text | escape }}</span>
                    {%- endif -%}
                  </div>
                  {%- if section.settings.expert_role != blank or section.settings.expert_date != blank -%}
                    <div class="mthp__expert-meta">
                      {%- if section.settings.expert_role != blank -%}· {{ section.settings.expert_role | escape }}{%- endif -%}
                      {%- if section.settings.expert_date != blank -%} · {{ section.settings.expert_date | escape }}{%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}

        </div>

        <div class="mthp__right">
          {%- if section.settings.hero_image != blank -%}
            <div class="mthp__img-wrap">
              <img
                src="{{ section.settings.hero_image | image_url: width: 900 }}"
                alt="{{ section.settings.hero_image.alt | escape }}"
                loading="eager"
                fetchpriority="high"
                width="900"
              >
            </div>
          {%- else -%}
            <div class="mthp__img-placeholder">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>

  {%- if section.settings.show_trust_bar and section.blocks.size > 0 -%}
    <div class="mthp__trust">
      {%- for block in section.blocks -%}
        <div class="mthp__trust-item" {{ block.shopify_attributes }}>
          {%- assign icon_file = block.settings.icon | prepend: 'icon-' | append: '.svg' -%}
          <span class="mthp__trust-icon">{{ icon_file | inline_asset_content }}</span>
          {%- if block.settings.trust_text != blank -%}
            <span class="mthp__trust-text">{{ block.settings.trust_text | escape }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "MT-HERO-PIC",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Lettertype"
    },
    {
      "type": "text",
      "id": "font_family",
      "label": "Google Font naam",
      "default": "Poppins"
    },
    {
      "type": "header",
      "content": "Sectie"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Achtergrond kleur",
      "default": "#f5f5f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding boven (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding onder (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_h",
      "min": 0,
      "max": 80,
      "step": 8,
      "unit": "px",
      "label": "Padding horizontaal (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Ruimte tussen tekst en foto",
      "default": 48
    },
    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Breadcrumb tonen",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumb_home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "breadcrumb_home_url",
      "label": "Home URL"
    },
    {
      "type": "text",
      "id": "breadcrumb_collection_label",
      "label": "Collectie label",
      "default": "Shop"
    },
    {
      "type": "header",
      "content": "Titel"
    },
    {
      "type": "textarea",
      "id": "title_text",
      "label": "Titel tekst",
      "default": "ALLE PRODUCTEN"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titel kleur",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Titel grootte (desktop)",
      "default": 56
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte (mobiel)",
      "default": 36
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Titel dikte",
      "options": [
        { "value": "300", "label": "300 — Light" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "500", "label": "500 — Medium" },
        { "value": "600", "label": "600 — Semi Bold" },
        { "value": "700", "label": "700 — Bold" },
        { "value": "800", "label": "800 — Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "min": 0,
      "max": 30,
      "step": 1,
      "label": "Titel letter-spacing (×0.01em)",
      "default": 14
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Titel tekst opmaak",
      "options": [
        { "value": "none",      "label": "Normaal" },
        { "value": "uppercase", "label": "HOOFDLETTERS" },
        { "value": "lowercase", "label": "kleine letters" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Ruimte onder titel",
      "default": 20
    },
    {
      "type": "header",
      "content": "Subtitel"
    },
    {
      "type": "checkbox",
      "id": "show_subtitle",
      "label": "Subtitel tonen",
      "default": true
    },
    {
      "type": "textarea",
      "id": "subtitle_text",
      "label": "Subtitel tekst",
      "default": "Ontdek onze huidverzorgingsproducten. Alles wat jij als man nodig hebt voor een goede en gezonde verzorging."
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitel kleur",
      "default": "#555550"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Subtitel lettergrootte",
      "default": 15
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitel dikte",
      "options": [
        { "value": "300", "label": "300 — Light" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "500", "label": "500 — Medium" }
      ],
      "default": "400"
    },
    {
      "type": "text",
      "id": "subtitle_line_height",
      "label": "Subtitel regelafstand",
      "default": "1.75"
    },
    {
      "type": "range",
      "id": "subtitle_max_width",
      "min": 300,
      "max": 700,
      "step": 4,
      "unit": "px",
      "label": "Subtitel max breedte",
      "default": 480
    },
    {
      "type": "header",
      "content": "Expert kaart"
    },
    {
      "type": "checkbox",
      "id": "show_expert_card",
      "label": "Expert kaart tonen",
      "default": true
    },
    {
      "type": "color",
      "id": "expert_card_bg",
      "label": "Kaart achtergrond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "expert_card_border",
      "label": "Kaart rand kleur",
      "default": "#e8e8e4"
    },
    {
      "type": "range",
      "id": "expert_card_radius",
      "min": 0,
      "max": 24,
      "step": 4,
      "unit": "px",
      "label": "Kaart afronding",
      "default": 12
    },
    {
      "type": "range",
      "id": "expert_card_padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Kaart padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "expert_card_margin_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Ruimte boven kaart",
      "default": 24
    },
    {
      "type": "range",
      "id": "expert_stars",
      "min": 0,
      "max": 5,
      "step": 1,
      "label": "Aantal sterren",
      "default": 5
    },
    {
      "type": "color",
      "id": "expert_star_color",
      "label": "Ster kleur",
      "default": "#00b67a"
    },
    {
      "type": "textarea",
      "id": "expert_review_text",
      "label": "Review tekst",
      "default": "Reversoskin combineert effectieve, wetenschappelijk onderbouwde ingrediënten met een dierproefvrije filosofie. De producten zijn geschikt voor alle huidtypes, van droge en gevoelige huid tot vette en onzuivere huid."
    },
    {
      "type": "color",
      "id": "expert_review_color",
      "label": "Review tekst kleur",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "expert_review_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Review tekst grootte",
      "default": 15
    },
    {
      "type": "image_picker",
      "id": "expert_photo",
      "label": "Expert foto (cirkel)"
    },
    {
      "type": "text",
      "id": "expert_name",
      "label": "Expert naam",
      "default": "Dr. Emma de Vries"
    },
    {
      "type": "color",
