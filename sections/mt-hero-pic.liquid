{%- assign mfont = section.settings.font_family | default: 'Poppins' -%}
{%- assign mfont_url = mfont | replace: ' ', '+' -%}
{%- assign ov_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}

{%- assign align_d = section.settings.text_align_desktop -%}
{%- assign align_m = section.settings.text_align_mobile -%}

{%- if align_d == 'left' -%}{%- assign items_d = 'flex-start' -%}
{%- elsif align_d == 'right' -%}{%- assign items_d = 'flex-end' -%}
{%- else -%}{%- assign items_d = 'center' -%}{%- endif -%}

{%- if align_m == 'left' -%}{%- assign items_m = 'flex-start' -%}
{%- elsif align_m == 'right' -%}{%- assign items_m = 'flex-end' -%}
{%- else -%}{%- assign items_m = 'center' -%}{%- endif -%}

{%- assign valign = section.settings.text_valign -%}
{%- if valign == 'top' -%}{%- assign justify = 'flex-start' -%}
{%- elsif valign == 'bottom' -%}{%- assign justify = 'flex-end' -%}
{%- else -%}{%- assign justify = 'center' -%}{%- endif -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family={{ mfont_url }}:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- style -%}
  #MT-HP-{{ section.id }} * { box-sizing: border-box; }

  /* ── HERO WRAPPER ── */
  #MT-HP-{{ section.id }} .mthp__hero {
    position: relative;
    width: calc(100% - {{ section.settings.hero_margin | times: 2 }}px);
    margin: 0 {{ section.settings.hero_margin }}px;
    height: {{ section.settings.hero_height_mobile }}px;
    border-radius: {{ section.settings.hero_border_radius }}px;
    overflow: hidden;
    background-color: #111111;
  }

  @media screen and (min-width: 768px) {
    #MT-HP-{{ section.id }} .mthp__hero {
      height: {{ section.settings.hero_height_desktop }}px;
    }
  }

  /* ── BACKGROUND IMAGE ── */
  #MT-HP-{{ section.id }} .mthp__bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  /* ── OVERLAY ── */
  #MT-HP-{{ section.id }} .mthp__overlay {
    position: absolute;
    inset: 0;
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ ov_opacity }};
    z-index: 1;
  }

  /* ── INNER: positions content within hero ── */
  #MT-HP-{{ section.id }} .mthp__inner {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ justify }};
    align-items: {{ items_m }};
    padding: {{ section.settings.content_padding_v }}px {{ section.settings.content_padding_h_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-HP-{{ section.id }} .mthp__inner {
      align-items: {{ items_d }};
      padding-left: {{ section.settings.content_padding_h_desktop }}px;
      padding-right: {{ section.settings.content_padding_h_desktop }}px;
    }
  }

  /* ── CONTENT BOX ── */
  #MT-HP-{{ section.id }} .mthp__content {
    display: flex;
    flex-direction: column;
    align-items: {{ items_m }};
    text-align: {{ align_m }};
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
  }

  @media screen and (min-width: 768px) {
    #MT-HP-{{ section.id }} .mthp__content {
      align-items: {{ items_d }};
      text-align: {{ align_d }};
    }
  }

  /* ── LABEL ── */
  #MT-HP-{{ section.id }} .mthp__label {
    font-family: '{{ mfont }}', sans-serif;
    display: inline-block;
    font-size: {{ section.settings.label_size }}px;
    font-weight: {{ section.settings.label_weight }};
    color: {{ section.settings.label_color }};
    letter-spacing: {{ section.settings.label_spacing | times: 0.01 }}em;
    text-transform: {{ section.settings.label_transform }};
    margin: 0 0 {{ section.settings.label_margin_bottom }}px;
    line-height: 1.4;
    {%- if section.settings.label_show_pill -%}
    background-color: {{ section.settings.label_pill_bg }};
    border-radius: {{ section.settings.label_pill_radius }}px;
    padding: 5px 16px;
    {%- endif -%}
  }

  /* ── HEADING ── */
  #MT-HP-{{ section.id }} .mthp__heading {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.heading_size_mobile }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    letter-spacing: {{ section.settings.heading_spacing | times: 0.01 }}em;
    text-transform: {{ section.settings.heading_transform }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    max-width: {{ section.settings.heading_max_width }}px;
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-HP-{{ section.id }} .mthp__heading {
      font-size: {{ section.settings.heading_size_desktop }}px;
    }
  }

  /* ── SUBTEXT ── */
  #MT-HP-{{ section.id }} .mthp__subtext {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.subtext_size_mobile }}px;
    font-weight: {{ section.settings.subtext_weight }};
    color: {{ section.settings.subtext_color }};
    line-height: {{ section.settings.subtext_line_height | divided_by: 100.0 }};
    max-width: {{ section.settings.subtext_max_width }}px;
    margin: 0 0 {{ section.settings.subtext_margin_bottom }}px;
  }

  @media screen and (min-width: 768px) {
    #MT-HP-{{ section.id }} .mthp__subtext {
      font-size: {{ section.settings.subtext_size_desktop }}px;
    }
  }

  /* ── BUTTON ── */
  #MT-HP-{{ section.id }} .mthp__btn {
    display: inline-block;
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.btn_size }}px;
    font-weight: {{ section.settings.btn_weight }};
    color: {{ section.settings.btn_color }};
    background-color: {{ section.settings.btn_bg }};
    border-radius: {{ section.settings.btn_radius }}px;
    border: {{ section.settings.btn_border_width }}px solid {{ section.settings.btn_border_color }};
    padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
    letter-spacing: {{ section.settings.btn_spacing | times: 0.01 }}em;
    text-transform: {{ section.settings.btn_transform }};
    text-decoration: none;
    margin-top: {{ section.settings.btn_margin_top }}px;
    line-height: 1;
    cursor: pointer;
  }
{%- endstyle -%}

<div id="MT-HP-{{ section.id }}">
  <div class="mthp__hero">

    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'mthp__bg-img',
          loading: 'eager',
          fetchpriority: 'high',
          alt: section.settings.heading,
          widths: '800, 1200, 1600, 2000, 2400'
      }}
    {%- endif -%}

    <div class="mthp__overlay"></div>

    <div class="mthp__inner">
      <div class="mthp__content">

        {%- if section.settings.show_label and section.settings.label_text != blank -%}
          <span class="mthp__label">{{ section.settings.label_text | escape }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mthp__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.subtext != blank -%}
          <p class="mthp__subtext">{{ section.settings.subtext | escape }}</p>
        {%- endif -%}

        {%- if section.settings.show_btn and section.settings.btn_text != blank -%}
          <a class="mthp__btn" href="{{ section.settings.btn_url }}">
            {{ section.settings.btn_text | escape }}
          </a>
        {%- endif -%}

      </div>
    </div>

  </div>
</div>

