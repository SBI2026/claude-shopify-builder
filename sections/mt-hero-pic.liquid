{%- assign mfont = section.settings.font_family | default: 'Poppins' -%}
{%- assign mfont_url = mfont | replace: ' ', '+' -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family={{ mfont_url }}:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

{%- style -%}
  #mthp-{{ section.id }},
  #mthp-{{ section.id }} * {
    box-sizing: border-box;
  }

  /* ── HERO AREA ── */
  #mthp-{{ section.id }} .mthp__area {
    background: {{ section.settings.section_bg }};
    padding: 32px 20px;
  }

  @media (min-width: 768px) {
    #mthp-{{ section.id }} .mthp__area {
      padding: {{ section.settings.padding_top }}px {{ section.settings.padding_h }}px {{ section.settings.padding_bottom }}px;
    }
  }

  #mthp-{{ section.id }} .mthp__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ── GRID ── */
  #mthp-{{ section.id }} .mthp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }

  @media (min-width: 768px) {
    #mthp-{{ section.id }} .mthp__grid {
      grid-template-columns: 1fr 1fr;
      gap: {{ section.settings.grid_gap }}px;
    }
  }

  /* ── LEFT COLUMN ── */
  #mthp-{{ section.id }} .mthp__left {
    display: flex;
    flex-direction: column;
  }

  /* ── BREADCRUMB ── */
  #mthp-{{ section.id }} .mthp__crumb {
    font-family: '{{ mfont }}', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #888884;
    margin-bottom: 24px;
    line-height: 1.4;
  }

  #mthp-{{ section.id }} .mthp__crumb a {
    color: #888884;
    text-decoration: none;
  }

  #mthp-{{ section.id }} .mthp__crumb a:hover {
    color: #555550;
  }

  /* ── TITLE ── */
  #mthp-{{ section.id }} .mthp__title {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    letter-spacing: {{ section.settings.title_letter_spacing | times: 0.01 }}em;
    text-transform: {{ section.settings.title_transform }};
    line-height: 1.1;
    margin: 0 0 {{ section.settings.title_margin_bottom }}px;
    padding: 0;
  }

  @media (min-width: 768px) {
    #mthp-{{ section.id }} .mthp__title {
      font-size: {{ section.settings.title_size_desktop }}px;
    }
  }

  /* ── SUBTITLE ── */
  #mthp-{{ section.id }} .mthp__subtitle {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    color: {{ section.settings.subtitle_color }};
    line-height: {{ section.settings.subtitle_line_height }};
    max-width: {{ section.settings.subtitle_max_width }}px;
    margin: 0;
    padding: 0;
  }

  /* ── RIGHT COLUMN / IMAGE ── */
  #mthp-{{ section.id }} .mthp__img-wrap {
    width: 100%;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    background: {{ section.settings.image_bg }};
    display: block;
    {%- unless section.settings.image_aspect == 'auto' -%}
    aspect-ratio: {{ section.settings.image_aspect }};
    {%- endunless -%}
  }

  #mthp-{{ section.id }} .mthp__img-wrap img {
    width: 100%;
    display: block;
    {%- if section.settings.image_aspect == 'auto' -%}
    height: auto;
    {%- else -%}
    height: 100%;
    object-fit: {{ section.settings.image_object_fit }};
    {%- endif -%}
  }

  #mthp-{{ section.id }} .mthp__img-placeholder {
    width: 100%;
    {%- if section.settings.image_aspect == 'auto' -%}
    aspect-ratio: 4 / 3;
    {%- else -%}
    aspect-ratio: {{ section.settings.image_aspect }};
    {%- endif -%}
    background: {{ section.settings.image_bg }};
    border-radius: {{ section.settings.image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #mthp-{{ section.id }} .mthp__img-placeholder svg {
    width: 64px;
    height: 64px;
    opacity: 0.2;
  }

  /* ── TRUST BAR ── */
  #mthp-{{ section.id }} .mthp__trust {
    background: {{ section.settings.trust_bg }};
    padding: {{ section.settings.trust_padding }}px 40px;
    display: flex;
    justify-content: space-evenly;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  #mthp-{{ section.id }} .mthp__trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  #mthp-{{ section.id }} .mthp__trust-item svg {
    width: {{ section.settings.trust_icon_size }}px;
    height: {{ section.settings.trust_icon_size }}px;
    color: {{ section.settings.trust_text_color }};
    flex-shrink: 0;
  }

  #mthp-{{ section.id }} .mthp__trust-text {
    font-family: '{{ mfont }}', sans-serif;
    font-size: {{ section.settings.trust_font_size }}px;
    font-weight: 400;
    color: {{ section.settings.trust_text_color }};
    line-height: 1.4;
    max-width: 220px;
  }

  /* ── MOBILE ── */
  @media (max-width: 767px) {
    #mthp-{{ section.id }} .mthp__trust {
      flex-direction: column;
      gap: 20px;
      padding: {{ section.settings.trust_padding }}px 20px;
    }
  }
{%- endstyle -%}

<div id="mthp-{{ section.id }}">

  <div class="mthp__area">
    <div class="mthp__inner">
      <div class="mthp__grid">

        <div class="mthp__left">

          {%- if section.settings.show_breadcrumb -%}
            <nav class="mthp__crumb" aria-label="Breadcrumb">
              <a href="{{ section.settings.breadcrumb_home_url }}">{{ section.settings.breadcrumb_home_label | escape }}</a>
              <span> / </span>
              <span>{{ section.settings.breadcrumb_collection_label | escape }}</span>
            </nav>
          {%- endif -%}

          {%- if section.settings.title_text != blank -%}
            <h1 class="mthp__title">{{ section.settings.title_text | escape }}</h1>
          {%- endif -%}

          {%- if section.settings.show_subtitle and section.settings.subtitle_text != blank -%}
            <p class="mthp__subtitle">{{ section.settings.subtitle_text | escape }}</p>
          {%- endif -%}

        </div>

        <div class="mthp__right">
          {%- if section.settings.hero_image != blank -%}
            <div class="mthp__img-wrap">
              <img
                src="{{ section.settings.hero_image | image_url: width: 900 }}"
                alt="{{ section.settings.hero_image.alt | escape }}"
                loading="eager"
                fetchpriority="high"
                width="900"
              >
            </div>
          {%- else -%}
            <div class="mthp__img-placeholder">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>

  {%- if section.settings.show_trust_bar and section.blocks.size > 0 -%}
    <div class="mthp__trust">
      {%- for block in section.blocks -%}
        <div class="mthp__trust-item" {{ block.shopify_attributes }}>
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- when 'return' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>
            {%- when 'smile' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            {%- when 'star' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- when 'shield' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- when 'check' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {%- when 'heart' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {%- when 'clock' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- when 'gift' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          {%- endcase -%}
          {%- if block.settings.trust_text != blank -%}
            <span class="mthp__trust-text">{{ block.settings.trust_text | escape }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "MT-HERO-PIC",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Lettertype"
    },
    {
      "type": "text",
      "id": "font_family",
      "label": "Google Font naam",
      "default": "Poppins"
    },
    {
      "type": "header",
      "content": "Sectie"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Achtergrond kleur",
      "default": "#f5f5f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding boven (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding onder (desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_h",
      "min": 0,
      "max": 80,
      "step": 8,
      "unit": "px",
      "label": "Padding horizontaal (desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Ruimte tussen tekst en foto",
      "default": 48
    },
    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Breadcrumb tonen",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumb_home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "breadcrumb_home_url",
      "label": "Home URL"
    },
    {
      "type": "text",
      "id": "breadcrumb_collection_label",
      "label": "Collectie label",
      "default": "Shop"
    },
    {
      "type": "header",
      "content": "Titel"
    },
    {
      "type": "textarea",
      "id": "title_text",
      "label": "Titel tekst",
      "default": "ALLE PRODUCTEN"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titel kleur",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "min": 24,
      "max": 96,
      "step": 4,
      "unit": "px",
      "label": "Titel grootte (desktop)",
      "default": 56
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte (mobiel)",
      "default": 36
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Titel dikte",
      "options": [
        { "value": "300", "label": "300 — Light" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "500", "label": "500 — Medium" },
        { "value": "600", "label": "600 — Semi Bold" },
        { "value": "700", "label": "700 — Bold" },
        { "value": "800", "label": "800 — Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "min": 0,
      "max": 30,
      "step": 1,
      "label": "Titel letter-spacing (×0.01em)",
      "default": 14
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Titel tekst opmaak",
      "options": [
        { "value": "none",      "label": "Normaal" },
        { "value": "uppercase", "label": "HOOFDLETTERS" },
        { "value": "lowercase", "label": "kleine letters" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Ruimte onder titel",
      "default": 20
    },
    {
      "type": "header",
      "content": "Subtitel"
    },
    {
      "type": "checkbox",
      "id": "show_subtitle",
      "label": "Subtitel tonen",
      "default": true
    },
    {
      "type": "textarea",
      "id": "subtitle_text",
      "label": "Subtitel tekst",
      "default": "Ontdek onze huidverzorgingsproducten. Alles wat jij als man nodig hebt voor een goede en gezonde verzorging."
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitel kleur",
      "default": "#555550"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Subtitel lettergrootte",
      "default": 15
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitel dikte",
      "options": [
        { "value": "300", "label": "300 — Light" },
        { "value": "400", "label": "400 — Regular" },
        { "value": "500", "label": "500 — Medium" }
      ],
      "default": "400"
    },
    {
      "type": "text",
      "id": "subtitle_line_height",
      "label": "Subtitel regelafstand",
      "default": "1.75"
    },
    {
      "type": "range",
      "id": "subtitle_max_width",
      "min": 300,
      "max": 700,
      "step": 4,
      "unit": "px",
      "label": "Subtitel max breedte",
      "default": 480
    },
    {
      "type": "header",
      "content": "Hero foto"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero foto rechts"
    },
    {
      "type": "select",
      "id": "image_aspect",
      "label": "Foto verhouding",
      "options": [
        { "value": "1/1",  "label": "Vierkant (1:1)" },
        { "value": "4/3",  "label": "Liggend (4:3)" },
        { "value": "3/4",  "label": "Staand (3:4)" },
        { "value": "auto", "label": "Automatisch" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Foto afronding",
      "default": 16
    },
    {
      "type": "select",
      "id": "image_object_fit",
      "label": "Foto opvulling",
      "options": [
        { "value": "cover",   "label": "Cover (bijsnijden)" },
        { "value": "contain", "label": "Contain (volledig zichtbaar)" }
      ],
      "default": "cover"
    },
    {
      "type": "color",
      "id": "image_bg",
      "label": "Foto achtergrond kleur",
      "default": "#e8e8e4"
    },
    {
      "type": "header",
      "content": "Trust balk"
    },
    {
      "type": "checkbox",
      "id": "show_trust_bar",
      "label": "Trust balk tonen",
      "default": true
    },
    {
      "type": "color",
      "id": "trust_bg",
      "label": "Trust balk achtergrond",
      "default": "#2d4a6b"
    },
    {
      "type": "range",
      "id": "trust_padding",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Trust balk padding",
      "default": 24
    },
    {
      "type": "color",
      "id": "trust_text_color",
      "label": "Trust balk tekstkleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "trust_icon_size",
      "min": 20,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Icoon grootte",
      "default": 32
    },
    {
      "type": "range",
      "id": "trust_font_size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Trust tekst grootte",
      "default": 14
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Vertrouwensbadge",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icoon",
          "options": [
            { "value": "truck",   "label": "Bezorging" },
            { "value": "return",  "label": "Retour" },
            { "value": "smile",   "label": "Smiley" },
            { "value": "star",    "label": "Ster" },
            { "value": "shield",  "label": "Schild" },
            { "value": "check",   "label": "Vinkje" },
            { "value": "heart",   "label": "Hart" },
            { "value": "clock",   "label": "Klok" },
            { "value": "gift",    "label": "Cadeau" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "trust_text",
          "label": "Tekst",
          "default": "Op werkdagen vóór 15:00 besteld, morgen in huis"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "MT-HERO-PIC",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "trust_text": "Op werkdagen vóór 15:00 besteld, morgen in huis"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "return",
            "trust_text": "30 Dagen Geld Terug & Gratis Retour"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "smile",
            "trust_text": "+5.000 Tevreden Klanten"
          }
        }
      ]
    }
  ]
}
{% endschema %}
