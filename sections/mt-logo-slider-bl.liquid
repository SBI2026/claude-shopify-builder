      "default": "#e8e8e4"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "Lijn onderaan tonen",
      "default": false
    },
    {
      "type": "color",
      "id": "border_bottom_color",
      "label": "Kleur lijn onder",
      "default": "#e8e8e4"
    },
    {
