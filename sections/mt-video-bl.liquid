<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- style -%}
  #mtvb-{{ section.id }},
  #mtvb-{{ section.id }} *,
  #mtvb-{{ section.id }} *::before,
  #mtvb-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  /* ── SECTION HEADER ROW ── */
  #mtvb-{{ section.id }} .mtvb__hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 {{ section.settings.padding_h }}px {{ section.settings.title_margin_bottom }}px;
  }

  #mtvb-{{ section.id }} .mtvb__title {
    font-family: 'Poppins', sans-serif;
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    line-height: 1.2;
    margin: 0;
    padding: 0;
    text-align: {{ section.settings.title_align }};
    flex: 1;
  }

  @media (min-width: 768px) {
    #mtvb-{{ section.id }} .mtvb__title {
      font-size: {{ section.settings.title_size }}px;
    }
  }

  /* ── MOBILE NAV (header-row arrows, hidden on desktop) ── */
  #mtvb-{{ section.id }} .mtvb__nav {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    margin-left: 16px;
  }

  @media (min-width: 768px) {
    #mtvb-{{ section.id }} .mtvb__nav {
      display: none;
    }
  }

  /* ── OUTER WRAPPER ── */
  #mtvb-{{ section.id }} .mtvb__outer {
    position: relative;
  }

  @media (min-width: 768px) {
    #mtvb-{{ section.id }} .mtvb__outer {
      padding-left: {{ section.settings.padding_h }}px;
      padding-right: {{ section.settings.padding_h }}px;
    }
  }

  /* ── VIEWPORT: mobile = scroll-snap centered, desktop = overflow hidden ── */
  #mtvb-{{ section.id }} .mtvb__vp {
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0 10vw;
  }

  #mtvb-{{ section.id }} .mtvb__vp::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 768px) {
    #mtvb-{{ section.id }} .mtvb__vp {
      overflow: hidden;
      scroll-snap-type: none;
    }
  }

  /* ── TRACK ── */
  #mtvb-{{ section.id }} .mtvb__track {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    will-change: transform;
  }

  /* ── CARD ── */
  #mtvb-{{ section.id }} .mtvb__card {
    flex: 0 0 80vw;
    scroll-snap-align: center;
    position: relative;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    aspect-ratio: 9 / 16;
    background: #111111;
    -webkit-tap-highlight-color: transparent;
  }

  @media (min-width: 768px) {
    #mtvb-{{ section.id }} .mtvb__card {
      flex: 0 0 auto;
      scroll-snap-align: none;
    }
  }

  /* ── POSTER (thumbnail layer) ── */
  #mtvb-{{ section.id }} .mtvb__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #mtvb-{{ section.id }} .mtvb__thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #mtvb-{{ section.id }} .mtvb__thumb--empty {
    background: #1a1a1a;
    position: absolute;
    inset: 0;
  }

  /* ── OVERLAY ── */
  #mtvb-{{ section.id }} .mtvb__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 50%);
    pointer-events: none;
  }

  /* ── PLAY BUTTON ── */
  #mtvb-{{ section.id }} .mtvb__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ section.settings.play_btn_size }}px;
    height: {{ section.settings.play_btn_size }}px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
    z-index: 2;
  }

  #mtvb-{{ section.id }} .mtvb__play:hover {
    background: #ffffff;
    transform: translate(-50%, -50%) scale(1.08);
  }

  /* ── CAPTION ── */
  #mtvb-{{ section.id }} .mtvb__caption {
    position: absolute;
    bottom: 16px;
    left: 16px;
    right: 16px;
    font-family: 'Poppins', sans-serif;
    font-size: {{ section.settings.caption_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: {{ section.settings.caption_color }};
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    pointer-events: none;
    z-index: 2;
  }

  /* ── PLAYER (inline video, hidden until play clicked) ── */
  #mtvb-{{ section.id }} .mtvb__player {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: #000;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
  }

  #mtvb-{{ section.id }} .mtvb__player iframe,
  #mtvb-{{ section.id }} .mtvb__player video {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  /* ── DESKTOP SIDE ARROWS (hidden on mobile) ── */
  #mtvb-{{ section.id }} .mtvb__sarr {
    display: none;
  }

  @media (min-width: 768px) {
    #mtvb-{{ section.id }} .mtvb__sarr {
      display: flex;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }

    #mtvb-{{ section.id }} .mtvb__sarr--prev {
      left: -20px;
    }

    #mtvb-{{ section.id }} .mtvb__sarr--next {
      right: -20px;
    }
  }

  /* ── ARROW SHARED STYLE ── */
  #mtvb-{{ section.id }} .mtvb__arr,
  #mtvb-{{ section.id }} .mtvb__sarr {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #ffffff;
    border: 1.5px solid #e0e0e0;
    color: #111111;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    padding: 0;
    flex-shrink: 0;
  }

  #mtvb-{{ section.id }} .mtvb__arr {
    display: flex;
  }

  #mtvb-{{ section.id }} .mtvb__arr:hover,
  #mtvb-{{ section.id }} .mtvb__sarr:hover {
    background: #111111;
    color: #ffffff;
    border-color: #111111;
  }
{%- endstyle -%}

<div
  class="mtvb"
  id="mtvb-{{ section.id }}"
  style="background: {{ section.settings.section_bg }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  {%- if section.settings.show_title and section.settings.title != blank -%}
    <div class="mtvb__hd">
      <h2 class="mtvb__title">{{ section.settings.title | escape }}</h2>
      {%- if section.blocks.size > 1 -%}
        <div class="mtvb__nav">
          <button class="mtvb__arr mtvb__arr--prev" aria-label="Vorige video">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="mtvb__arr mtvb__arr--next" aria-label="Volgende video">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="mtvb__outer" id="mtvb-wrap-{{ section.id }}">
      {%- if section.blocks.size > 1 -%}
        <button class="mtvb__sarr mtvb__sarr--prev" aria-label="Vorige video">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
      {%- endif -%}

      <div class="mtvb__vp" id="mtvb-vp-{{ section.id }}">
        <div class="mtvb__track" id="mtvb-tr-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- assign vid_url = block.settings.video_url | default: '' -%}
            {%- if vid_url contains 'youtube.com' or vid_url contains 'youtu.be' -%}
              {%- assign vid_type = 'youtube' -%}
              {%- if vid_url contains 'youtu.be/' -%}
                {%- assign yt_id = vid_url | split: 'youtu.be/' | last | split: '?' | first | split: '&' | first -%}
              {%- elsif vid_url contains 'shorts/' -%}
                {%- assign yt_id = vid_url | split: 'shorts/' | last | split: '?' | first | split: '&' | first -%}
              {%- else -%}
                {%- assign yt_id = vid_url | split: 'v=' | last | split: '&' | first | split: '?' | first -%}
              {%- endif -%}
            {%- elsif vid_url contains 'vimeo.com' -%}
              {%- assign vid_type = 'vimeo' -%}
              {%- assign yt_id = '' -%}
            {%- elsif vid_url contains 'tiktok.com' -%}
              {%- assign vid_type = 'tiktok' -%}
              {%- assign yt_id = '' -%}
            {%- else -%}
              {%- assign vid_type = 'direct' -%}
              {%- assign yt_id = '' -%}
            {%- endif -%}

            <div
              class="mtvb__card mtvb__card--real"
              data-video-url="{{ vid_url | escape }}"
              data-video-type="{{ vid_type }}"
              {{ block.shopify_attributes }}
            >
              {%- if forloop.first -%}
                {%- assign img_loading = 'eager' -%}
              {%- else -%}
                {%- assign img_loading = 'lazy' -%}
              {%- endif -%}
              <div class="mtvb__poster">
                {%- if vid_type == 'youtube' and yt_id != '' -%}
                  <img
                    class="mtvb__thumb"
                    src="https://img.youtube.com/vi/{{ yt_id }}/hqdefault.jpg"
                    alt="{{ block.settings.caption | escape }}"
                    width="480"
                    height="360"
                    loading="{{ img_loading }}"
                    {%- if forloop.first -%}fetchpriority="high"{%- endif -%}
                  >
                {%- elsif vid_type == 'direct' and vid_url != '' -%}
                  <video
                    class="mtvb__thumb"
                    src="{{ vid_url | escape }}"
                    muted
                    playsinline
                    preload="metadata"
                    tabindex="-1"
                  ></video>
                {%- elsif vid_type == 'vimeo' -%}
                  <div class="mtvb__thumb mtvb__thumb--empty" data-fetch-vimeo="{{ vid_url | escape }}"></div>
                {%- else -%}
                  <div class="mtvb__thumb mtvb__thumb--empty"></div>
                {%- endif -%}
                <div class="mtvb__overlay"></div>
                <button class="mtvb__play" aria-label="Video afspelen">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="#111111"><polygon points="5,3 19,12 5,21"/></svg>
                </button>
                {%- if block.settings.caption != blank -%}
                  <div class="mtvb__caption">{{ block.settings.caption | escape }}</div>
                {%- endif -%}
              </div>
              <div class="mtvb__player"></div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      {%- if section.blocks.size > 1 -%}
        <button class="mtvb__sarr mtvb__sarr--next" aria-label="Volgende video">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  var SID  = '{{ section.id }}';
  var root = document.getElementById('mtvb-' + SID);
  var wrap = document.getElementById('mtvb-wrap-' + SID);
  var vp   = document.getElementById('mtvb-vp-' + SID);
  var track= document.getElementById('mtvb-tr-' + SID);
  if (!track || !wrap) return;

  var GAP    = {{ section.settings.card_gap }};
  var PER    = 3;
  var curIdx = PER;
  var busy   = false;

  function isDesk() { return window.innerWidth >= 768; }

  /* ── HELPERS ── */
  function reals() { return Array.from(track.querySelectorAll('.mtvb__card--real')); }
  function rmClones() { track.querySelectorAll('.mtvb__card--clone').forEach(function(c){ c.remove(); }); }
  function step() { var c = track.querySelector('.mtvb__card'); return c ? c.offsetWidth + GAP : 0; }

  /* ── DESKTOP: infinite transform slider ── */
  function setupDesk() {
    rmClones();
    track.style.transition = 'none';
    track.style.transform  = '';

    var rs = reals(), n = rs.length;
    if (!n) return;

    var cw = (vp.offsetWidth - (PER - 1) * GAP) / PER;
    rs.forEach(function(c){ c.style.width = cw + 'px'; });

    /* clone last PER before, first PER after */
    rs.slice(-PER).slice().reverse().forEach(function(c){
      var cl = c.cloneNode(true);
      cl.classList.remove('mtvb__card--real'); cl.classList.add('mtvb__card--clone');
      cl.style.width = cw + 'px';
      track.prepend(cl);
    });
    rs.slice(0, PER).forEach(function(c){
      var cl = c.cloneNode(true);
      cl.classList.remove('mtvb__card--real'); cl.classList.add('mtvb__card--clone');
      cl.style.width = cw + 'px';
      track.append(cl);
    });

    curIdx = PER;
    moveTo(curIdx, false);
  }

  function moveTo(idx, anim) {
    track.style.transition = anim ? 'transform 0.38s ease' : 'none';
    track.style.transform  = 'translateX(' + (-idx * step()) + 'px)';
    curIdx = idx;
  }

  track.addEventListener('transitionend', function(){
    busy = false;
    var n = reals().length;
    if (curIdx >= n + PER)  { moveTo(PER, false); }
    else if (curIdx <= 0)   { moveTo(n,   false); }
  });

  /* ── MOBILE: scroll-snap ── */
  function setupMob() {
    rmClones();
    track.style.transition = 'none';
    track.style.transform  = '';
    reals().forEach(function(c){ c.style.width = ''; });
    vp.scrollLeft = 0;
    curIdx = 0;
  }

  function mobStep() {
    var c = track.querySelector('.mtvb__card');
    return c ? c.offsetWidth + GAP : vp.offsetWidth;
  }

  /* ── INIT ── */
  function init() {
    if (isDesk()) { setupDesk(); } else { setupMob(); }
  }

  /* ── ARROWS: both header-nav (mobile) + side (desktop) ── */
  function goPrev() {
    if (isDesk()) {
      if (busy) return; busy = true; moveTo(curIdx - 1, true);
    } else {
      vp.scrollBy({ left: -mobStep(), behavior: 'smooth' });
    }
  }
  function goNext() {
    if (isDesk()) {
      if (busy) return; busy = true; moveTo(curIdx + 1, true);
    } else {
      vp.scrollBy({ left: mobStep(), behavior: 'smooth' });
    }
  }

  root.querySelectorAll('.mtvb__arr--prev, .mtvb__sarr--prev').forEach(function(b){
    b.addEventListener('click', goPrev);
  });
  root.querySelectorAll('.mtvb__arr--next, .mtvb__sarr--next').forEach(function(b){
    b.addEventListener('click', goNext);
  });

  /* ── RESIZE ── */
  var rT;
  window.addEventListener('resize', function(){ clearTimeout(rT); rT = setTimeout(init, 200); });

  /* ── VIMEO THUMBNAIL FETCH ── */
  root.querySelectorAll('.mtvb__thumb--empty[data-fetch-vimeo]').forEach(function(el){
    var url = el.getAttribute('data-fetch-vimeo');
    if (!url) return;
    fetch('https://vimeo.com/api/oembed.json?url=' + encodeURIComponent(url))
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (!d.thumbnail_url) return;
        var img = document.createElement('img');
        img.className = 'mtvb__thumb';
        img.src = d.thumbnail_url;
        img.alt = '';
        img.loading = 'lazy';
        el.parentNode.insertBefore(img, el);
        el.remove();
      })
      .catch(function(){});
  });

  /* ── VIDEO EMBED BUILDER ── */
  function ytID(u)  { var m = u.match(/(?:v=|youtu\.be\/|shorts\/)([a-zA-Z0-9_-]{11})/); return m ? m[1] : ''; }
  function viID(u)  { var m = u.match(/vimeo\.com\/(\d+)/);  return m ? m[1] : ''; }
  function ttID(u)  { var m = u.match(/video\/(\d+)/);       return m ? m[1] : ''; }

  var attrs = 'frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:100%;"';

  function buildEmbed(url, type) {
    if (type === 'youtube') {
      return '<iframe src="https://www.youtube.com/embed/' + ytID(url) + '?autoplay=1&rel=0" ' + attrs + '></iframe>';
    }
    if (type === 'vimeo') {
      return '<iframe src="https://player.vimeo.com/video/' + viID(url) + '?autoplay=1&dnt=1" ' + attrs + '></iframe>';
    }
    if (type === 'tiktok') {
      return '<iframe src="https://www.tiktok.com/embed/v2/' + ttID(url) + '" ' + attrs + '></iframe>';
    }
    return '<video src="' + url + '" autoplay controls playsinline style="width:100%;height:100%;background:#000;"></video>';
  }

  /* ── PLAY BUTTON: open in-card ── */
  root.addEventListener('click', function(e) {
    var btn = e.target.closest('.mtvb__play');
    if (!btn) return;
    var card = btn.closest('.mtvb__card');
    if (!card) return;

    var url  = card.getAttribute('data-video-url');
    var type = card.getAttribute('data-video-type');
    if (!url) return;

    var poster = card.querySelector('.mtvb__poster');
    var player = card.querySelector('.mtvb__player');

    player.innerHTML = buildEmbed(url, type);
    player.style.display = 'block';
    if (poster) poster.style.display = 'none';
  });

  /* ── DESIGN MODE ── */
  document.addEventListener('shopify:section:load', function(e){
    if (e.target.querySelector('#mtvb-' + SID)) { init(); }
  });

  init();
})();
</script>

{% schema %}
{
  "name": "MT-VIDEO-BL",
  "settings": [
    {
      "type": "header",
      "content": "Sectie"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Achtergrond kleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding boven",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding onder",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_h",
      "min": 0,
      "max": 80,
      "step": 8,
      "unit": "px",
      "label": "Padding horizontaal (desktop)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Titel"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Titel tonen",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel",
      "default": "Volg onze community"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 18,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte (desktop)",
      "default": 36
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Titel grootte (mobiel)",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Titel dikte",
      "options": [
        { "value": "300", "label": "Light 300" },
        { "value": "400", "label": "Regular 400" },
        { "value": "500", "label": "Medium 500" },
        { "value": "600", "label": "Semi-Bold 600" },
        { "value": "700", "label": "Bold 700" }
      ],
      "default": "400"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titel kleur",
      "default": "#111111"
    },
    {
      "type": "select",
      "id": "title_align",
      "label": "Titel uitlijning",
      "options": [
        { "value": "left",   "label": "Links" },
        { "value": "center", "label": "Midden" },
        { "value": "right",  "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "min": 0,
      "max": 80,
      "step": 8,
      "unit": "px",
      "label": "Afstand onder titel",
      "default": 24
    },
    {
      "type": "header",
      "content": "Video kaarten"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "label": "Afronding kaart",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 12,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Ruimte tussen kaarten",
      "default": 20
    },
    {
      "type": "range",
      "id": "play_btn_size",
      "min": 40,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Play knop grootte",
      "default": 56
    },
    {
      "type": "range",
      "id": "caption_size",
      "min": 11,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Caption tekst grootte",
      "default": 14
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption tekst kleur",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
